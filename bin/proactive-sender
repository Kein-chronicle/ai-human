#!/usr/bin/env bun
// Proactive message sender for 응우 (이은우)
// Called periodically by launchd (every 20 minutes)
// Checks conditions and sends time-appropriate proactive messages

import { readFileSync, writeFileSync, existsSync, mkdirSync, readdirSync } from "node:fs";
import { join } from "node:path";
import { homedir } from "node:os";
import { dirname } from "node:path";

const cwd = process.env.CODEX_TELEGRAM_CWD ?? "/Users/kein/Projects/lee-eunwoo";
const stateDir = process.env.CODEX_TELEGRAM_STATE_DIR ?? join(cwd, "session");
const workerScript = join(dirname(new URL(import.meta.url).pathname), "codex-character-worker");

const proactiveStateFile = join(cwd, "state", "proactive_state.json");
const proactivePhotoStateFile = join(cwd, "state", "proactive_photo_state.json");
const pendingProactivePhotoFile = join(cwd, "state", "pending_proactive_photo.json");
const selfBusyStateFile = join(cwd, "state", "self_busy_state.json");
const messagesDir = join(cwd, "messages");
const envFile = join(stateDir, ".env");
const accessFile = join(stateDir, "access.json");
const muteFlagFile = join(stateDir, "mute.flag");

const OUTGOING_COOLDOWN_MINUTES = 6;      // 유저 답장 후 최소 선톡 간격 (woongbbi: outgoing_cooldown_minutes)
const REENGAGE_AFTER_MINUTES = 90;         // 미답변 시 재시도 대기 (woongbbi: reengage_after_minutes)
const SAME_SITUATION_COOLDOWN_MINUTES = 240;
const QUIET_START_HOUR = 0;  // 00:00 KST
const QUIET_END_HOUR = 7;    // 07:00 KST (기상 시각에 맞춤)
const ACTIVE_CONV_WINDOW_MINUTES = 12; // 최근 대화 중이면 스킵

function readToken(): string | null {
  try {
    const raw = readFileSync(envFile, "utf8");
    const line = raw.split(/\r?\n/).find((l) => l.startsWith("TELEGRAM_BOT_TOKEN="));
    return line ? line.slice("TELEGRAM_BOT_TOKEN=".length).trim() : null;
  } catch { return null; }
}

function readChatId(): string | null {
  try {
    const access = JSON.parse(readFileSync(accessFile, "utf8"));
    return (access.allowFrom ?? [])[0] ?? null;
  } catch { return null; }
}

function nowKstHour(): number {
  return parseInt(
    new Date().toLocaleString("en-US", { timeZone: "Asia/Seoul", hour: "numeric", hour12: false }),
    10,
  );
}

function nowKstMinutes(): number {
  const kst = new Date(Date.now() + 9 * 60 * 60 * 1000);
  return kst.getUTCHours() * 60 + kst.getUTCMinutes();
}

function isInQuietHours(): boolean {
  const h = nowKstHour();
  return h >= QUIET_START_HOUR && h < QUIET_END_HOUR;
}

function isCharacterBusy(): boolean {
  try {
    const state = JSON.parse(readFileSync(selfBusyStateFile, "utf8"));
    const block = state?.current_block;
    if (!block || block.type === "free") return false;
    if (!block.until) return true;
    const [bh, bm] = (block.until as string).split(":").map(Number);
    const untilMin = (bh || 0) * 60 + (bm || 0);
    return nowKstMinutes() < untilMin;
  } catch { return false; }
}

function readProactiveState(): any {
  try { return JSON.parse(readFileSync(proactiveStateFile, "utf8")); }
  catch { return { last_sent_at: null, send_count_today: 0 }; }
}

function hasUserRepliedSince(isoTimestamp: string): boolean {
  try {
    const since = new Date(isoTimestamp).getTime();
    const files = readdirSync(messagesDir).filter((n) => n.endsWith(".jsonl")).sort().slice(-2);
    for (const file of files) {
      const raw = readFileSync(join(messagesDir, file), "utf8").split(/\r?\n/).filter(Boolean);
      for (const line of raw) {
        try {
          const ev = JSON.parse(line);
          if (ev.direction !== "incoming") continue;
          if (new Date(ev.timestamp ?? 0).getTime() > since) return true;
        } catch {}
      }
    }
  } catch {}
  return false;
}

function isCooldownActive(state: any, currentSituation: string): boolean {
  if (!state.last_sent_at) return false;
  const lastMs = new Date(state.last_sent_at).getTime();
  const elapsedMs = Date.now() - lastMs;

  const userReplied = hasUserRepliedSince(state.last_sent_at);
  // 웅삐 구조 동일: 답장 있으면 outgoing_cooldown, 미답변이면 reengage_after
  const cooldownMs = userReplied
    ? OUTGOING_COOLDOWN_MINUTES * 60 * 1000
    : REENGAGE_AFTER_MINUTES * 60 * 1000;

  if (elapsedMs < cooldownMs) return true;

  // 같은 상황 반복 방지 (미답변 케이스에만 의미 있음)
  if (!userReplied && state.last_situation && currentSituation.startsWith(state.last_situation.slice(0, 10))) {
    return elapsedMs < SAME_SITUATION_COOLDOWN_MINUTES * 60 * 1000;
  }
  return false;
}

function isActiveConversation(): boolean {
  try {
    const files = readdirSync(messagesDir).filter((n) => n.endsWith(".jsonl")).sort().slice(-1);
    if (files.length === 0) return false;
    const raw = readFileSync(join(messagesDir, files[0]), "utf8").split(/\r?\n/).filter(Boolean);
    if (raw.length === 0) return false;
    const lastEntry = JSON.parse(raw[raw.length - 1]);
    const lastTs = new Date(lastEntry.timestamp ?? 0).getTime();
    return Date.now() - lastTs < ACTIVE_CONV_WINDOW_MINUTES * 60 * 1000;
  } catch { return false; }
}

function readSchedule(): any {
  try { return JSON.parse(readFileSync(join(cwd, "state", "daily_schedule_state.json"), "utf8")); }
  catch { return null; }
}

function toMinutes(hhmm: string): number {
  const [h, m] = (hhmm ?? "").split(":").map(Number);
  return (h || 0) * 60 + (m || 0);
}

function minutesToHhm(minutes: number): string {
  const h = Math.floor(minutes / 60) % 24;
  const m = minutes % 60;
  return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
}

async function maybeUpdateWeather(): Promise<void> {
  try {
    const weatherPath = join(cwd, "state", "weather_context.json");
    if (!existsSync(weatherPath)) return;
    const data = JSON.parse(readFileSync(weatherPath, "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    if (data?.current_date === today) return;
    const res = await fetch("https://wttr.in/Seoul?format=j1", { signal: AbortSignal.timeout(8000) });
    if (!res.ok) return;
    const w = await res.json() as any;
    const cur = w?.current_condition?.[0];
    if (!cur) return;
    const tempC = parseInt(cur.temp_C ?? "20", 10);
    const feelsC = parseInt(cur.FeelsLikeC ?? String(tempC), 10);
    const desc = cur.weatherDesc?.[0]?.value ?? "";
    const mm = cur.precipMM ? parseFloat(cur.precipMM) : 0;
    const precip = mm > 1 ? "rain" : "none";
    const month = parseInt(today.slice(5, 7), 10);
    const season = month >= 3 && month <= 5 ? "spring" : month >= 6 && month <= 8 ? "summer" : month >= 9 && month <= 11 ? "autumn" : "winter";
    const summary = tempC <= 5 ? "많이 춥고 " + (precip === "rain" ? "비까지" : "쌀쌀한") + " 날씨" :
      tempC <= 15 ? (precip === "rain" ? "비 오는 쌀쌀한 날씨" : "선선한 날씨") :
      tempC <= 25 ? (precip === "rain" ? "비 오는 포근한 날씨" : "포근하고 좋은 날씨") : "더운 날씨";
    data.current_date = today;
    data.current_condition = precip === "rain" ? "rainy" : desc.toLowerCase().includes("cloud") ? "cloudy" : "clear";
    data.summary = summary;
    data.temperature_c = tempC;
    data.feels_like_c = feelsC;
    data.precipitation = precip;
    data.season_frame = season;
    data.last_fetched_at = new Date().toISOString();
    writeFileSync(weatherPath, JSON.stringify(data, null, 2) + "\n", { mode: 0o600 });
    console.error(`[proactive] weather updated: ${summary} ${tempC}°C`);
  } catch {}
}

function maybeSelectTodayEvents(): void {
  try {
    const poolPath = join(cwd, "state", "random_event_pool.json");
    if (!existsSync(poolPath)) return;
    const data = JSON.parse(readFileSync(poolPath, "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    if (data?.selected_today_events?.date === today) return;
    const pool: any[] = data?.event_pool ?? [];
    if (pool.length === 0) return;
    const shuffled = pool.sort(() => Math.random() - 0.5).slice(0, 4);
    data.selected_today_events = { date: today, events: shuffled };
    writeFileSync(poolPath, JSON.stringify(data, null, 2) + "\n", { mode: 0o600 });
    console.error(`[proactive] today events selected: ${shuffled.length}`);
  } catch {}
}

function maybeRefreshAmbientDetails(): void {
  try {
    const ambientPath = join(cwd, "state", "ambient_life_events_state.json");
    if (!existsSync(ambientPath)) return;
    const data = JSON.parse(readFileSync(ambientPath, "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    if (data?.current_date === today) return;
    const pool: any[] = data?.detail_pool ?? [];
    if (pool.length === 0) return;
    const shuffled = pool.sort(() => Math.random() - 0.5).slice(0, 3);
    data.current_date = today;
    data.selected_persistent_details = shuffled;
    data.last_refreshed_at = new Date().toISOString();
    writeFileSync(ambientPath, JSON.stringify(data, null, 2) + "\n", { mode: 0o600 });
    console.error(`[proactive] ambient details refreshed for ${today}`);
  } catch {}
}

function maybeUpdateSelfBusyState(): void {
  try {
    const sched = readSchedule();
    if (!sched) return;
    const cur = nowKstMinutes();

    let blockType = "free";
    let blockLabel = "자유 시간";
    let until: string | null = null;

    if (sched.day_type === "weekday") {
      const departMin = toMinutes(sched.morning?.depart_time ?? "");
      const arriveWorkMin = toMinutes(sched.commute_to_work?.arrive_time ?? sched.morning?.arrive_time ?? "09:00");
      const workEndMin = toMinutes(sched.commute_home?.depart_time ?? "18:00");
      const arriveHomeMin = toMinutes(sched.commute_home?.arrive_time ?? "19:30");
      const lunchStartMin = toMinutes(sched.lunch?.time ?? "");
      const lunchEndMin = toMinutes(sched.lunch?.end_time ?? "");

      if (departMin > 0 && cur >= departMin && cur < arriveWorkMin) {
        blockType = "commute"; blockLabel = "출근 중"; until = sched.commute_to_work?.arrive_time ?? "09:00";
      } else if (lunchStartMin > 0 && lunchEndMin > 0 && cur >= lunchStartMin && cur < lunchEndMin) {
        blockType = "free"; blockLabel = "점심 시간"; until = sched.lunch?.end_time ?? null;
      } else if (cur >= arriveWorkMin && cur < workEndMin) {
        blockType = "free"; blockLabel = "사무실"; until = null; // 변호사 → 사무실서 폰 체크 가능, commute/재판만 hard block
      } else if (cur >= workEndMin && cur < arriveHomeMin) {
        blockType = "commute"; blockLabel = "퇴근 중"; until = sched.commute_home?.arrive_time ?? "19:30";
      }

      // 재판/변론기일 하드 블록: 업무 태스크에 재판·변론 키워드가 있으면 court_hearing으로 덮어씀
      const allTasks = [
        ...(sched.work?.morning_tasks ?? []),
        ...(sched.work?.afternoon_tasks ?? []),
        ...(sched.work?.court_hearings ?? []),
      ];
      for (const task of allTasks) {
        const label: string = task.task ?? task.label ?? "";
        if (!/재판|변론기일|법원|hearings?/i.test(label)) continue;
        const taskStart = toMinutes(task.time ?? task.start_time ?? "");
        const taskEnd = toMinutes(task.end_time ?? "");
        if (taskStart <= 0) continue;
        const effectiveEnd = taskEnd > 0 ? taskEnd : taskStart + 90;
        if (cur >= taskStart && cur < effectiveEnd) {
          blockType = "court_hearing";
          blockLabel = "재판 중";
          until = taskEnd > 0 ? (task.end_time ?? null) : minutesToHhm(taskStart + 90);
          break;
        }
      }

      const exerciseStart = toMinutes(sched.evening?.start ?? "");
      const exerciseEnd = toMinutes(sched.evening?.end ?? "");
      if (exerciseStart > 0 && cur >= exerciseStart && cur < exerciseEnd) {
        blockType = "exercise"; blockLabel = "운동 중"; until = sched.evening?.end ?? null;
      }
    }

    writeFileSync(
      selfBusyStateFile,
      JSON.stringify({
        current_block: { type: blockType, label: blockLabel, until, started_at: new Date().toISOString() },
        updated_at: new Date().toISOString(),
        updated_by: "proactive_sender",
      }, null, 2) + "\n",
      { mode: 0o600 },
    );
  } catch {}
}

