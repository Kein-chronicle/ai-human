function maybeUpdateMediaWatchContext(): void {
  const path = join(cwd, "state", "media_watch_context.json");
  const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
  let existing: any = {};
  try { existing = JSON.parse(readFileSync(path, "utf8")); } catch {}
  if (existing.current_date === today) return;

  const h = nowKstHour();
  let timeBlock = "evening";
  if (h >= 21) timeBlock = "night_wind_down";
  else if (h >= 18) timeBlock = "evening";
  else timeBlock = "daytime";

  const formats = ["longform", "shorts", "news_clip"];
  const categories = ["news_briefing", "sports_highlight", "travel_vlog", "documentary_short", "variety_clips"];
  writeFileSync(path, JSON.stringify({
    ...existing,
    current_date: today,
    current_time_block: timeBlock,
    last_known_format: formats[Math.floor(Math.random() * formats.length)],
    last_known_category: categories[Math.floor(Math.random() * categories.length)],
    updated_at: new Date(Date.now() + 9 * 3600 * 1000).toISOString(),
  }, null, 2));
}

function maybeUpdateDayContext(): void {
  const path = join(cwd, "state", "day_context.json");
  const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
  let existing: any = {};
  try { existing = JSON.parse(readFileSync(path, "utf8")); } catch {}
  if (existing.date === today) return;

  const seeds = [
    "자연스럽고 생활감 있는 흐름으로 이어지는 하루",
    "별 일 없는 조용한 하루, 루틴대로 흘러가는 중",
    "조금 피곤하지만 할 거 다 하는 하루",
    "생각보다 일이 많아진 하루",
    "잔잔하게 괜찮은 하루",
  ];
  const residues = ["neutral", "calm_and_open", "slightly_tired", "focused", "neutral"];
  const ri = Math.floor(Math.random() * residues.length);

  writeFileSync(path, JSON.stringify({
    ...existing,
    date: today,
    day_type: [0, 6].includes(new Date().getDay()) ? "weekend" : "weekday",
    workday: ![0, 6].includes(new Date().getDay()),
    day_summary_seed: seeds[ri],
    carry_over_from_previous_day: {
      sleep_debt: Math.random() > 0.7 ? "medium" : "low",
      emotional_residue: residues[ri],
    },
    morning_context: { status: "inactive", summary: "", tone_bias: "neutral" },
    last_updated_at: new Date(Date.now() + 9 * 3600 * 1000).toISOString(),
  }, null, 2));
}

function updateChatRuntimeSnapshot(): void {
  const path = join(cwd, "state", "chat_runtime_snapshot.json");
  const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
  const h = nowKstHour();
  let timeBlock = "evening";
  if (h >= 7 && h < 9) timeBlock = "morning_commute";
  else if (h >= 9 && h < 12) timeBlock = "work_morning";
  else if (h >= 12 && h < 14) timeBlock = "lunch";
  else if (h >= 14 && h < 18) timeBlock = "work_afternoon";
  else if (h >= 18 && h < 21) timeBlock = "evening_commute";
  else if (h >= 21) timeBlock = "night_home";
  else timeBlock = "early_morning";

  let presence: any = {};
  let variance: any = {};
  let daySat: any = {};
  let pattern: any = {};
  let weather: any = {};
