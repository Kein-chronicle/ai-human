function buildShareEventSection(): string[] {
  try {
    const ctx = JSON.parse(readFileSync(shareEventContextFile, "utf8"));
    if (!ctx?.allow_proactive_image_share) return [];
    const lastShare = ctx.last_image_share_at;
    if (lastShare) {
      const cooldownMs = (ctx.image_share_cooldown_minutes ?? 30) * 60 * 1000;
      if (Date.now() - new Date(lastShare).getTime() < cooldownMs) return [];
    }
    const events: string[] = ctx.preferred_photo_events ?? [];
    if (events.length === 0) return [];
    return [
      `[사진 공유 기회]`,
      `자연스러운 타이밍에 사진 먼저 보내도 됨: ${events.slice(0, 3).join(" / ")}`,
      `↑ 대화 흐름상 어색하지 않을 때만. 쿨다운 ${ctx.image_share_cooldown_minutes ?? 30}분.`,
      "",
    ];
  } catch { return []; }
}

function buildOutfitContextSection(): string[] {
  try {
    const presets = JSON.parse(readFileSync(outfitPresetsFile, "utf8"));
    const h = nowKstHour();
    const nowMin = h * 60 + new Date(Date.now() + 9 * 3600 * 1000).getMinutes();

    // dress_done 기준으로 잠옷/출근복 분기
    let dressDoneMin = -1;
    let departMin = -1;
    try {
      const sched = JSON.parse(readFileSync(join(cwd, "state", "daily_schedule_state.json"), "utf8"));
      const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
      if (sched?.date === today && sched.day_type === "weekday") {
        const dd = sched.morning?.morning_prep?.dress_done ?? "";
        const dp = sched.morning?.depart_time ?? sched.commute_to_work?.depart_time ?? "";
        if (dd) {
          const [dh, dm] = dd.split(":").map(Number);
          dressDoneMin = dh * 60 + dm;
        }
        if (dp) {
          const [ph, pm] = dp.split(":").map(Number);
          departMin = ph * 60 + pm;
        }
      }
    } catch {}

    let key = "night_home";
    if (dressDoneMin >= 0 && nowMin < dressDoneMin && h >= 6 && h < 10) {
      // 기상~옷 입기 전: 잠옷
      const preset = presets?.presets?.["night_home"];
      const overall = preset?.overall ?? "홈웨어 또는 잠옷";
      return [
        `[현재 복장] — 아침 준비 중 (아직 옷 안 갈아입음, dress_done ${Math.floor(dressDoneMin/60)}:${String(dressDoneMin%60).padStart(2,"0")} 전)`,
        overall,
        `↑ 사진 생성 시: 잠옷/홈웨어 착용 + 집 실내 배경만. 카페·길거리 등 야외 배경 금지.`,
        "",
      ];
    } else if (departMin >= 0 && dressDoneMin >= 0 && nowMin >= dressDoneMin && nowMin < departMin) {
      // 옷 갈아입음~출발 전: 출근복 + 집 실내
      key = "morning_commute";
      const preset = presets?.presets?.[key];
      const overall = preset?.overall ?? "출근 복장";
      return [
        `[현재 복장] — 출근 준비 완료, 아직 집 안 (출발 ${Math.floor(departMin/60)}:${String(departMin%60).padStart(2,"0")} 예정)`,
        overall,
        `↑ 사진 생성 시: 출근복 착용 + 집 실내(현관/거울 앞). 아직 밖 아님.`,
        "",
      ];
    } else {
      if (h >= 7 && h < 9) key = "morning_commute";
      else if (h >= 9 && h < 12) key = "work_morning";
      else if (h >= 12 && h < 14) key = "lunch_break";
      else if (h >= 14 && h < 18) key = "work_afternoon";
      else if (h >= 18 && h < 21) key = "evening_commute";
      else key = "night_home";
      const preset = presets?.presets?.[key];
      if (!preset?.overall) return [];
      return [`[현재 복장]`, preset.overall, `↑ 사진 생성 시 복장 일관성 유지.`, ""];
    }
  } catch { return []; }
}

