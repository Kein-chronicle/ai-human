const recentConversationMemoryFile = join(cwd, "state", "recent_conversation_memory.json");
const moodTimelineFile = join(cwd, "state", "mood_timeline.json");
const insideJokesFile = join(cwd, "state", "inside_jokes_and_memories.json");
const weeklyConversationSummaryFile = join(cwd, "state", "weekly_conversation_summary.json");
const counterpartStateFile = join(cwd, "state", "counterpart_state_memory.json");
const phraseRepetitionGuardFile = join(cwd, "state", "phrase_repetition_guard_state.json");
const timeMicroDetailFile = join(cwd, "state", "time_micro_detail_pool.json");
const ambientLifeEventsFile = join(cwd, "state", "ambient_life_events_state.json");
