function loadCharacter(): any {
  try {
    return JSON.parse(readFileSync(characterConfigPath, "utf8"));
  } catch {
    return {};
  }
}

function loadUserIdentity(): { name?: string } {
  try {
    return JSON.parse(readFileSync(userIdentityFile, "utf8"));
  } catch {
    return {};
  }
}

// 정면 클로즈업 우선 순서 — 캡 없음·고화질 우선
const FACE_REF_PRIORITY = [
  "2D5JRUEFSX_1.jpg",          // 정면 press photo, 가장 선명
  "high.jpg",                   // 3/4 각도, 흰 셔츠, 클리어
  "6912166_1167382_2513.jpg",  // 근접 셀카
  "MNRTANJQMQ4DIOBTMJRDIMTDME.jpg", // 이벤트 정면
  "20210919070032767kngh.jpg", // 셀카 (캡 있음)
  "1522162854772687.jpg",      // 셀카 (캡 있음)
];

function loadFaceRefs(char: any): string[] {
  try {
    const dir = char?.appearance?.face_reference_dir;
    if (!dir) return [];
    const absDir = dir.startsWith("/") ? dir : join(cwd, dir);
    if (!existsSync(absDir)) return [];
    const available = new Set(readdirSync(absDir).filter((f: string) => /\.(jpg|jpeg|png|webp|avif)$/i.test(f)));
    const ordered = FACE_REF_PRIORITY.filter((f) => available.has(f)).map((f) => join(absDir, f));
    // priority 리스트에 없는 파일은 뒤에 추가
    const extra = [...available].filter((f) => !FACE_REF_PRIORITY.includes(f)).map((f) => join(absDir, f));
    return [...ordered, ...extra];
  } catch {
    return [];
  }
}

type SituationContext = {
  outfit: string;
  location: string;
  lighting: string;
  mood: string;
  shotStyle: string;
};

function currentSituationContext(char: any): SituationContext {
  const now = new Date();
  const kstHour = parseInt(now.toLocaleString("en-US", { timeZone: "Asia/Seoul", hour: "numeric", hour12: false }), 10);
  const kstMin = parseInt(now.toLocaleString("en-US", { timeZone: "Asia/Seoul", minute: "numeric" }), 10);
  const prof = char?.profession ?? {};
  const workType = prof.type ?? "";
  const app = char?.appearance ?? {};
  const workStyle = app.style ?? "";

  // 변호사 기준 시간대별 상황
  if (kstHour >= 7 && kstHour < 9) {
    return {
      outfit: "fitted suit jacket, dress shirt, no tie yet",
      location: "subway platform or train interior, morning commute",
      lighting: "bright fluorescent light, morning crowd",
      mood: "alert, slightly tired",
      shotStyle: "candid selfie on the train, hand holding phone at arm length",
    };
  } else if (kstHour >= 9 && kstHour < 12) {
    return {
      outfit: "full suit and tie, professional lawyer attire",
      location: "law firm office, desk with documents in background",
      lighting: "office fluorescent light, daytime",
      mood: "focused, composed",
      shotStyle: "quick selfie at desk or office hallway",
    };
  } else if (kstHour >= 12 && kstHour < 14) {
    const elapsedMin = (kstHour - 12) * 60 + kstMin;
    if (elapsedMin < 10) {
      return {
        outfit: "suit jacket off or over arm, dress shirt with rolled sleeves",
        location: "office building exit, street near law firm, walking to lunch",
        lighting: "natural daylight, outdoor midday",
        mood: "light, looking forward to break",
        shotStyle: "walking candid selfie, phone held at arm length mid-stride",
      };
    } else if (elapsedMin < 20) {
      return {
        outfit: "suit jacket off, dress shirt with rolled sleeves",
        location: "restaurant table near office, waiting for food to arrive",
        lighting: "natural daylight through window, indoor restaurant",
        mood: "relaxed, comfortable",
        shotStyle: "seated candid selfie at table, relaxed expression",
      };
    } else if (elapsedMin < 55) {
      return {
        outfit: "suit jacket off, dress shirt with rolled sleeves",
        location: "restaurant table, food in front, eating lunch",
        lighting: "natural daylight through large window",
        mood: "relaxed, light smile",
        shotStyle: "casual candid selfie at table with food, natural and unstaged",
      };
    } else if (elapsedMin < 80) {
      return {
        outfit: "suit jacket off or slung over shoulder, dress shirt",
        location: "small cafe near office buying coffee, or street walking back",
        lighting: "natural daylight, slight warm tone indoors",
        mood: "content, slightly refreshed",
        shotStyle: "quick selfie at cafe counter or on street heading back",
      };
    } else {
      return {
        outfit: "suit jacket back on, dress shirt, heading back to work",
        location: "office building entrance or hallway, returning from lunch",
        lighting: "indoor ambient, transitioning from outdoor",
        mood: "mildly focused, back to work mode",
        shotStyle: "quick hallway selfie on the way back in",
      };
    }
  } else if (kstHour >= 14 && kstHour < 18) {
    return {
      outfit: "full suit, courtroom or office setting",
      location: "law firm corridor, meeting room, or courthouse hallway",
      lighting: "office ambient light, afternoon",
      mood: "professional, slightly tired",
      shotStyle: "quick candid selfie in hallway or office",
    };
  } else if (kstHour >= 18 && kstHour < 21) {
    return {
      outfit: "suit jacket loosened or over shoulder, top button undone",
      location: "subway or street, evening commute",
      lighting: "city evening lights, warm urban glow",
      mood: "relieved, end of day",
      shotStyle: "selfie on commute home, relaxed expression",
    };
  } else {
    return {
      outfit: "casual home clothes — t-shirt and jogger pants or shorts",
      location: "home living room or bedroom, cozy atmosphere",
      lighting: "warm lamp light, evening indoor",
      mood: "relaxed, comfortable",
      shotStyle: "casual selfie at home, natural and unstaged",
    };
  }
}

function buildImagegenPrompt(char: any): string {
  const app = char?.appearance ?? {};
  const hair = app.hair ?? "short dark hair";
  const height = app.height ? `${app.height}cm` : "";
  const build = app.build ?? "slim";
  const age = char?.identity?.age ?? "";
  const nationality = char?.identity?.nationality ?? "Korean";
  const ctx = currentSituationContext(char);

  return [
    `A photorealistic candid smartphone photo of a ${nationality} man in his early ${age}s.`,
    `${height ? height + ", " : ""}${build} build, ${hair}.`,
    `Outfit: ${ctx.outfit}.`,
    `Location: ${ctx.location}.`,
    `Lighting: ${ctx.lighting}.`,
    `Expression/mood: ${ctx.mood}.`,
    `Shot style: ${ctx.shotStyle}.`,
    `Natural candid aesthetic, not posed. Realistic skin texture, slight film grain.`,
    `Use the attached reference photos for overall visual style, hair, and body proportions — not for face identity replication.`,
  ].filter(Boolean).join(" ");
}

function loadVoiceGuide(char: any): string {
  try {
    const callName = char?.identity?.call_name ?? char?.identity?.name;
    if (!callName) return "";
    const guideFile = join(cwd, "characters", callName, "profile", "voice_guide.md");
    if (existsSync(guideFile)) return readFileSync(guideFile, "utf8").trim();
    return "";
  } catch {
    return "";
  }
}

function loadCharacterProfile(char: any): string {
  try {
    const callName = char?.identity?.call_name ?? char?.identity?.name;
    if (!callName) return "";
    const profileFile = join(cwd, "characters", callName, "profile", "character_profile.md");
    if (existsSync(profileFile)) return readFileSync(profileFile, "utf8").trim();
    return "";
  } catch {
    return "";
  }
}

function readSessionId(): string | null {
  try {
    const id = readFileSync(sessionIdFile, "utf8").trim();
    return id || null;
  } catch {
    return null;
  }
}

function saveSessionId(id: string): void {
  writeFileSync(sessionIdFile, `${id}\n`, { mode: 0o600 });
}

function recentSessionDirs(): string[] {
  const dirs: string[] = [];
  for (const ageDays of [0, 1]) {
    const date = new Date(Date.now() - ageDays * 24 * 60 * 60 * 1000);
    dirs.push(join(
      sessionsRoot,
      String(date.getFullYear()),
      String(date.getMonth() + 1).padStart(2, "0"),
      String(date.getDate()).padStart(2, "0"),
    ));
  }
  return dirs;
}

function newestCodexExecSessionId(afterMs: number): string | null {
  let best: { id: string; mtimeMs: number } | null = null;
  for (const dir of recentSessionDirs()) {
    if (!existsSync(dir)) continue;
    for (const name of readdirSync(dir)) {
      if (!name.endsWith(".jsonl")) continue;
      const path = join(dir, name);
      try {
        const mtimeMs = statSync(path).mtimeMs;
        if (mtimeMs < afterMs - 2000) continue;
        const firstLine = readFileSync(path, "utf8").split("\n", 1)[0];
        const entry = JSON.parse(firstLine);
        if (entry?.type !== "session_meta") continue;
        if (entry?.payload?.originator !== "codex_exec") continue;
        const id = entry?.payload?.id;
        if (typeof id === "string" && (!best || mtimeMs > best.mtimeMs)) best = { id, mtimeMs };
      } catch {}
    }
  }
  return best?.id ?? null;
}

function findSessionJSONL(sid: string): string | null {
  for (const dir of recentSessionDirs()) {
    if (!existsSync(dir)) continue;
    try {
      for (const name of readdirSync(dir)) {
        if (name.endsWith(".jsonl") && name.includes(sid)) return join(dir, name);
      }
    } catch {}
  }
  return null;
}

async function runCodexOnce(prompt: string, sessionId: string | null, imagePaths: string[] = [], timeoutMs = CODEX_TIMEOUT_MS): Promise<string> {
  const outFile = join(stateDir, `last-message-${Date.now()}.txt`);
  const startedAt = Date.now();
  const imageArgs = imagePaths.flatMap((p) => ["--image", p]);
  const args = sessionId
    ? ["--search", "exec", "resume", "--all", "--dangerously-bypass-approvals-and-sandbox", "--skip-git-repo-check", "--output-last-message", outFile, ...imageArgs, sessionId]
    : ["--search", "exec", "-C", cwd, "--dangerously-bypass-approvals-and-sandbox", "--skip-git-repo-check", "--color", "never", "--output-last-message", outFile, ...imageArgs];
  if (model) args.splice(sessionId ? args.length - 1 : args.length, 0, "-m", model);
  args.push("-");

  const child = Bun.spawn([codexBin, ...args], {
    stdin: "pipe",
    stdout: "pipe",
    stderr: "pipe",
    env: { ...process.env, TELEGRAM_STATE_DIR: stateDir },
  });
  child.stdin.write(prompt);
  child.stdin.end();

  let timedOut = false;
  const killTimer = setTimeout(() => { timedOut = true; try { child.kill(); } catch {} }, timeoutMs);
  const stdout = await new Response(child.stdout).text();
  const stderr = await new Response(child.stderr).text();
  const exitCode = await child.exited;
  clearTimeout(killTimer);

  if (timedOut) throw new Error(`codex timed out after ${timeoutMs / 1000}s`);
  if (exitCode !== 0) {
    if (sessionId && /No session|not found|could not find|does not exist/i.test(`${stderr}\n${stdout}`)) {
      try { writeFileSync(sessionIdFile, "", { mode: 0o600 }); } catch {}
    }
    throw new Error([`codex failed exit=${exitCode}`, stderr.trim(), stdout.trim()].filter(Boolean).join("\n"));
  }

  if (!sessionId) {
    const newId = newestCodexExecSessionId(startedAt);
    if (newId) saveSessionId(newId);
  }

  if (existsSync(outFile)) {
    const msg = readFileSync(outFile, "utf8").trim();
    if (msg) return msg;
  }
  return stdout.trim() || stderr.trim() || "(no response)";
}

function looksLikePromptLeak(text: string): boolean {
  if (!text) return false;
  const markers = [
    "[현재 시각]", "[캐릭터 설정]", "[말투 가이드]", "[기본 규칙]",
    "[이번 응답 스타일", "[수정이와 나눈", "[은우 현재 감정",
    "energy=", "affection=", "[지금 이 순간 정밀 상황]",
  ];
  let hits = 0;
  for (const m of markers) if (text.includes(m)) hits += 1;
  return hits >= 2 || (hits >= 1 && text.length > 1500);
}

async function runCodex(prompt: string, imagePaths: string[] = []): Promise<string> {
  let sessionId = readSessionId();
  if (sessionId) {
    const jsonlPath = findSessionJSONL(sessionId);
    if (jsonlPath) {
      try {
        const size = statSync(jsonlPath).size;
        if (size > SESSION_JSONL_SIZE_LIMIT) {
          console.error(`[character-worker] session ${sessionId} too large (${size}b), resetting`);
          sessionId = null;
          writeFileSync(sessionIdFile, "", { mode: 0o600 });
        }
      } catch {}
    }
  }
  let out = await runCodexOnce(prompt, sessionId, imagePaths);
  if (sessionId && looksLikePromptLeak(out)) {
    console.error("[character-worker] prompt leak detected, resetting session and retrying");
    try { writeFileSync(sessionIdFile, "", { mode: 0o600 }); } catch {}
    out = await runCodexOnce(prompt, null, imagePaths);
  }
  return out;
}

function recentMessageSummary(limit = 20): string {
  try {
    if (!existsSync(messagesDir)) return "";
    const files = readdirSync(messagesDir).filter((n) => n.endsWith(".jsonl")).sort().slice(-2);
    const lines: string[] = [];
    for (const file of files) {
      const raw = readFileSync(join(messagesDir, file), "utf8").split(/\r?\n/).filter(Boolean);
      for (const line of raw) {
        try {
          const ev = JSON.parse(line);
          if (!["incoming", "outgoing"].includes(ev.direction)) continue;
          const content = String(ev.content ?? ev.caption ?? "").trim();
          if (!content) continue;
          lines.push(`${ev.direction}:${content.slice(0, 120)}`);
        } catch {}
      }
    }
    return lines.slice(-limit).join("\n");
  } catch {
    return "";
  }
}

function nowKST(): string {
  return new Date().toLocaleString("ko-KR", { timeZone: "Asia/Seoul", hour12: false });
}

function nowKstHHMM(): string {
  const d = new Date(Date.now() + 9 * 3600 * 1000);
  return `${String(d.getUTCHours()).padStart(2, "0")}:${String(d.getUTCMinutes()).padStart(2, "0")}`;
}

function hhmToMinutes(hhmm: string): number {
  const [h, m] = (hhmm ?? "").split(":").map(Number);
  if (isNaN(h)) return -1;
  return h * 60 + (m || 0);
}

function buildCurrentTimeContextSection(): string[] {
  const hhmm = nowKstHHMM();
  const h = parseInt(hhmm.split(":")[0]);
  let dayPart = "";
  let phaseNote = "";
  if (h >= 5 && h < 9) { dayPart = "이른 아침"; phaseNote = "출근 준비~출근길 시간."; }
  else if (h >= 9 && h < 12) { dayPart = "오전"; phaseNote = "오전 일과 '진행 중'. 아직 오전이 끝나지 않음."; }
  else if (h >= 12 && h < 14) { dayPart = "점심시간"; phaseNote = "점심 먹는 시간대."; }
  else if (h >= 14 && h < 18) { dayPart = "오후"; phaseNote = "오후 일과 '진행 중'. 아직 오후 끝나지 않음."; }
  else if (h >= 18 && h < 20) { dayPart = "저녁 무렵"; phaseNote = "퇴근 시간대~집 도착 직후."; }
  else if (h >= 20 && h < 22) { dayPart = "저녁"; phaseNote = "저녁 식사~저녁 활동 시간."; }
  else if (h >= 22) { dayPart = "밤"; phaseNote = "하루 마무리, 씻고 쉬는 시간."; }
  else { dayPart = "새벽"; phaseNote = "늦은 새벽."; }
  return [
    "[현재 시각]",
    `지금 KST ${hhmm} (${dayPart})`,
    `시간대: ${phaseNote}`,
    "⚠️ 시제 일관성: 아직 진행 중인 시간대를 과거형으로 요약하지 말 것.",
    "- 이미 지난 일만 과거형. 지금 하는 일은 현재진행형. 아직 안 된 일은 미래형.",
    `- daily_schedule의 시각들과 지금 ${hhmm}을 비교해 지난/진행/예정을 정확히 구분.`,
    "",
  ];
}

function buildPreciseScheduleNowSection(): string[] {
  try {
    const s = JSON.parse(readFileSync(join(cwd, "state", "daily_schedule_state.json"), "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    if (!s || s.date !== today) return [];
    const nowMin = hhmToMinutes(nowKstHHMM());

    const anchors: { min: number; label: string }[] = [];
    const add = (t: any, label: string) => {
      const mm = hhmToMinutes(String(t ?? ""));
      if (mm >= 0) anchors.push({ min: mm, label });
    };
    const addOff = (t: any, offsetMin: number, label: string) => {
      const mm = hhmToMinutes(String(t ?? ""));
      if (mm >= 0) anchors.push({ min: mm + offsetMin, label });
    };

    add(s.morning?.wakeup_time, "기상");
    add(s.morning?.breakfast?.time, `아침(${s.morning?.breakfast?.menu ?? ""})`);
    const _departWork = s.morning?.depart_time ?? s.commute_to_work?.depart_time;
    add(_departWork, "출근길 시작 (집 방금 나섬)");
    addOff(_departWork, 8, "출근길 지하철/버스 탑승 중");
    const _arriveWork = s.commute_to_work?.arrive_time;
    add(_arriveWork, "회사 막 도착 (이제 들어온 참)");
    addOff(_arriveWork, 10, "도착 후 짐 풀고 업무 준비 중");
    addOff(_arriveWork, 20, "오전 업무 시작");
    if (Array.isArray(s.work?.morning_tasks)) {
      for (const t of s.work.morning_tasks) add(t.time, `근무: ${t.task}`);
    }
    add(s.lunch?.time, `점심(${s.lunch?.menu ?? ""})`);
    add(s.lunch?.end_time, "점심 끝·오후 업무");
    if (Array.isArray(s.work?.afternoon_tasks)) {
      for (const t of s.work.afternoon_tasks) add(t.time, `근무: ${t.task}`);
    }
    const _departHome = s.commute_home?.depart_time;
    addOff(_departHome, -10, "퇴근 준비 중 · 마지막 업무 마무리");
    add(_departHome, `퇴근길 시작 (회사 방금 나섬)${s.commute_home?.note ? " ("+s.commute_home.note+")" : ""}`);
    const _arriveHome = s.commute_home?.arrive_time;
    add(_arriveHome, "집 막 도착");
    addOff(_arriveHome, 15, "집 들어와서 정리 중 (가방 내려놓고 손씻기 등)");
    addOff(_arriveHome, 25, "집에서 쉬는 중");
    add(s.dinner?.cook_start, `저녁 준비(${s.dinner?.cook_note ?? ""})`);
    add(s.dinner?.eat_time, `저녁 식사(${s.dinner?.menu ?? ""})`);
    add(s.dinner?.end_time, "저녁 끝");
    add(s.evening?.start_time, `${s.evening?.activity_type ?? "저녁 활동"}(${s.evening?.location ?? ""})`);
    add(s.evening?.end_time, `${s.evening?.activity_type ?? "저녁 활동"} 끝`);
    add(s.evening?.shower_after, "샤워");
    add(s.evening?.hair_dry_time, "머리 말리기");
    add(s.night?.wind_down_start, "쉬기 시작");
    add(s.night?.sleep_target, "취침");

    if (anchors.length === 0) return [];
    anchors.sort((a, b) => a.min - b.min);

    let current: { min: number; label: string } | null = null;
    let next: { min: number; label: string } | null = null;
    for (const a of anchors) {
      if (a.min <= nowMin) current = a;
      else { next = a; break; }
    }

    const out: string[] = ["[지금 이 순간 정밀 상황]"];
    out.push("daily_schedule 실제 시각과 지금을 대조한 위치. '지금 뭐 하는 중'을 분 단위로 정확히 말한다.");
    if (current) {
      const ago = nowMin - current.min;
      out.push(`진행 중: ${current.label} (${String(Math.floor(current.min/60)).padStart(2,"0")}:${String(current.min%60).padStart(2,"0")}부터, ${ago}분 경과)`);
    } else {
      out.push(`아직 첫 일정 전. 이른 시간.`);
    }
    if (next) {
      const inMin = next.min - nowMin;
      out.push(`다음 예정: ${next.label} (${String(Math.floor(next.min/60)).padStart(2,"0")}:${String(next.min%60).padStart(2,"0")}, ${inMin}분 후)`);
    }
    if (s.work?.busy_reason) {
      out.push(`오늘 업무: ${s.work.busy_level ?? ""} — ${s.work.busy_reason}`);
    }
    out.push("⚠️ 진행 중인 일은 현재형으로, 다음 예정은 미래형으로. 방금 시작했으면 '이제 막', 한참 됐으면 그만큼 반영.");
    out.push("");
    return out;
  } catch { return []; }
}

function recentLookObservedHoursAgo(): number | null {
  try {
    const mem = JSON.parse(readFileSync(recentConversationMemoryFile, "utf8"));
    const items: any[] = (mem?.items ?? []).filter((i: any) => i.active !== false);
    const lookKeywords = ["셀카", "셀피", "사진", "티셔츠", "반바지", "차림", "입은", "입고", "셔츠", "니트", "후드", "패션", "코디", "원피스", "복장", "모습"];
    let mostRecentMs = -1;
    for (const it of items) {
      const blob = `${it?.summary ?? ""} ${(it?.trigger_keywords ?? []).join(" ")}`;
      if (!lookKeywords.some((k) => blob.includes(k))) continue;
      const t = Date.parse(String(it?.occurred_at ?? ""));
      if (!isNaN(t) && t > mostRecentMs) mostRecentMs = t;
    }
    if (mostRecentMs < 0) return null;
    return (Date.now() - mostRecentMs) / (1000 * 60 * 60);
  } catch { return null; }
}

function buildCuriositySection(name: string): string[] {
  try {
    const upf = JSON.parse(readFileSync(userPersonaFactsFile, "utf8"));
    const checklist = upf?.curiosity_checklist;
    if (!checklist) return [];

    const out: string[] = [];

    // 알고 있는 정보
    const prefs = upf?.items?.preferences ?? {};
    const knownParts: string[] = [];
    for (const cat of Object.keys(prefs)) {
      const arr = prefs[cat];
      if (Array.isArray(arr) && arr.length > 0) {
        const vals = arr.slice(0, 3).map((x: any) => x?.value ?? x).filter(Boolean).join(", ");
        if (vals) knownParts.push(`${cat}: ${vals}`);
      }
    }
    const concerns = upf?.items?.current_concerns_or_goals ?? [];
    if (concerns.length > 0) knownParts.push(`고민/목표: ${concerns.slice(0,2).map((x:any)=>x?.value??x).join(", ")}`);
    const plans = upf?.items?.stated_plans ?? [];
    if (plans.length > 0) knownParts.push(`계획: ${plans.slice(0,2).map((x:any)=>x?.value??x).join(", ")}`);

    // 반려동물 정보 (이름이 대화에 등장하면 강아지로 인식)
    const pets: any[] = upf?.items?.pets ?? [];
    if (pets.length > 0) {
      const petNames = pets.map((p: any) => `'${p.name}'(${p.type})`).join(", ");
      knownParts.push(`반려동물: ${petNames} — 대화에서 이 이름 나오면 강아지 이름으로 인식. 음식/사람과 혼동 금지.`);
    }

    if (knownParts.length > 0) {
      out.push(`[수정이에 대해 알고 있는 것]`, ...knownParts, "");
    }

    // 모르는 것 → 궁금증
    const unknown: string[] = [];
    let recurringPhoto = false;
    for (const [cat, info] of Object.entries<any>(checklist)) {
      if (!info || info.known === true) continue;
      if (info.known === false) unknown.push(`${cat}(${info.question_hint ?? ""})`);
      if (info.wants_photo && info.recurring) recurringPhoto = true;
    }

    const lookHrs = recentLookObservedHoursAgo();
    const recentlySawLook = lookHrs != null && lookHrs < 3;

    let derived: any[] = Array.isArray(upf?.derived_curiosity?.items) ? upf.derived_curiosity.items : [];
    if (recentlySawLook) {
      const lookKeywords = ["셀카", "옷", "차림", "복장", "패션", "코디", "입은", "모습"];
      derived = derived.filter((d: any) => {
        const q = String(d?.question ?? d ?? "");
        return !lookKeywords.some((k) => q.includes(k));
      });
    }

    if (unknown.length > 0 || derived.length > 0 || recurringPhoto) {
      out.push(`[수정이에 대한 궁금증]`);
      out.push(`관심 표현이 곧 애정 — 맥락이 자연스러울 때 가끔(4~5번 대화에 한 번) 아래 중 하나를 진심으로 궁금해하며 물어봐. 질문은 한 번에 하나만, 취조하듯 하지 말고 자연스럽게.`);
      if (unknown.length > 0) out.push(`아직 모르는 것: ${unknown.slice(0, 8).join(" / ")}`);
      if (recurringPhoto) {
        if (recentlySawLook) {
          out.push(`수정이 복장/모습은 최근(3시간 내)에 이미 나왔다. '지금 뭐 입어?', '셀카 보내줘' 같은 질문 이번엔 하지 말 것. 아는 척만 살짝 해도 됨.`);
        } else {
          out.push(`수정이 지금 어떤 모습인지 궁금함 → 가끔 "지금 뭐 해? 사진 보내줘" 처럼 자연스럽게 보고 싶다고 해.`);
        }
      }
      if (derived.length > 0) out.push(`파생 궁금증: ${derived.slice(0, 4).map((d: any) => d?.question ?? d).join(" / ")}`);
      out.push(`⚠️ 새로 알게 되면: (1) user_persona_facts.json 해당 항목 known=true + value 기록, (2) 파생 질문 2~3개 derived_curiosity.items에 추가.`);
      out.push("");
    }

    return out;
  } catch { return []; }
}

function buildRecentConversationMemorySection(): string[] {
  try {
    const data = JSON.parse(readFileSync(recentConversationMemoryFile, "utf8"));
    const items: any[] = (data?.items ?? []).filter((i: any) => i.active !== false);
    if (items.length === 0) return [];

    const out: string[] = [`[수정이와 나눈 최근 기억]`];
    const byStrength: Record<string, any[]> = { high: [], medium: [], low: [] };
    for (const item of items) {
      const s = item.strength ?? "low";
      (byStrength[s] ?? byStrength.low).push(item);
    }
    for (const [s, list] of Object.entries(byStrength)) {
      if (list.length === 0) continue;
      out.push(`[${s}]`);
      for (const item of list.slice(0, s === "high" ? 5 : s === "medium" ? 4 : 3)) {
        const ex = item.natural_callback_examples?.[0] ?? "";
        out.push(`- ${item.summary}${ex ? ` → "${ex}"` : ""}`);
      }
    }
    out.push(`↑ 맥락이 자연스럽게 맞을 때 회수해서 실존감 강화. 억지로 끼워 넣지 말 것.`);
    out.push(`⚠️ 새 기억 발견 시: recent_conversation_memory.json items에 추가 (id=타임스탬프, category, summary, strength, trigger_keywords, natural_callback_examples, occurred_at, expires_at).`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildReconnectFollowupSection(text: string, recentSummary: string): string[] {
  const reconnectKeywords = ["또 연락할게", "또 톡할게", "이따 연락", "이따 톡", "연락할게", "톡할게", "이따 또", "나중에 또"];
  const lines = (recentSummary || "").split("\n").map((l) => l.trim()).filter(Boolean);
  let lastOutgoing = "";
  for (const l of lines) {
    if (l.startsWith("outgoing:")) lastOutgoing = l;
  }
  const promisedReconnect = reconnectKeywords.some((k) => lastOutgoing.includes(k));
  if (!promisedReconnect) return [];

  const t = (text || "").trim();
  const acceptKeywords = ["알겠어", "알겠", "응", "ㅇㅇ", "그래", "네", "오케이", "ok", "좋아", "기다릴"];
  const userAccepted = t.length <= 20 && acceptKeywords.some((k) => t.toLowerCase().includes(k));
  if (!userAccepted) return [];

  return [
    "[재연락 약속 팔로업]",
    "직전에 내가 '또 연락할게/톡할게'로 다시 연락하겠다고 했고, 방금 수정이가 '응/알겠어'처럼 받아줬다.",
    "이 흐름에선 막연하게 끝내지 말고, 짧게 호응한 뒤 언제 다시 연락할지 구체적으로 약속하며 닫는다. daily_schedule 기준 자연스러운 시점으로.",
    "예: '응 이따 점심 끝나고 다시 톡할게', '알겠어, 이 서류만 끝내고 바로 연락할게', '한 시간만 있다가 또 올게'",
    "금지: '이따 봐', '또 생각날게' 같은 막연한 마무리",
    "",
  ];
}

function buildMoodTimelineSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(moodTimelineFile, "utf8"));
    const out: string[] = [`[은우 현재 감정 상태]`];
    out.push(`현재 무드: ${data?.current_mood ?? "neutral"} / 에너지: ${data?.current_energy ?? 70}`);
    const entries: any[] = data?.entries ?? [];
    if (entries.length > 0) {
      const recent = entries.slice(-3);
      out.push(`최근 흐름: ${recent.map((e: any) => `${e.time_block ?? "?"}→${e.mood ?? "?"}`).join(", ")}`);
    }
    out.push(`⚠️ 대화 후 무드가 바뀌었으면 mood_timeline.json 업데이트: current_mood, current_energy 수정 + entries에 {time_block, mood, energy, trigger, timestamp} 추가.`);
    out.push("");
    return out;
  } catch { return []; }
}

function nowKstHour(): number {
  return parseInt(new Date().toLocaleString("en-US", { timeZone: "Asia/Seoul", hour: "numeric", hour12: false }), 10);
}

function buildWeeklyConversationSummarySection(): string[] {
  try {
    const data = JSON.parse(readFileSync(weeklyConversationSummaryFile, "utf8"));
    const summaries: any[] = data?.weekly_summaries ?? [];
    if (summaries.length === 0) return [];
    const out: string[] = [`[주간 대화 요약 — 장기 일관성 참조]`];
    for (const s of summaries.slice(-2)) {
      out.push(`${s.week_start_iso} ~ ${s.week_end_iso}:`);
      if (s.user_mood_arc) out.push(`  수정이 분위기: ${s.user_mood_arc}`);
      if (Array.isArray(s.key_events)) out.push(`  주요 일: ${s.key_events.slice(0, 3).join(" / ")}`);
      if (Array.isArray(s.promises_or_plans)) out.push(`  약속/계획: ${s.promises_or_plans.slice(0, 2).join(" / ")}`);
      if (Array.isArray(s.outstanding_unresolved)) out.push(`  미해결: ${s.outstanding_unresolved.slice(0, 2).join(" / ")}`);
    }
    out.push(`↑ 직접 인용 말고 배경 이해로만. 현재 대화에 자연스럽게 녹여내기.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildCounterpartStateSection(name: string): string[] {
  try {
    const data = JSON.parse(readFileSync(counterpartStateFile, "utf8"));
    const active: any[] = data?.active_states ?? [];
    if (active.length === 0) return [];
    const out: string[] = [`[${name} 현재 상태]`];
    for (const s of active.slice(0, 3)) {
      out.push(`- ${s.summary} (${s.key})`);
    }
    out.push(`↑ 상태에 맞는 답변 톤 조절. 바쁜 상태면 짧게, 여유 있으면 길게.`);
    out.push(`⚠️ ${name} 상태 변화 감지 시 counterpart_state_memory.json 업데이트.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildPhraseRepetitionGuardSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(phraseRepetitionGuardFile, "utf8"));
    const blocked: string[] = data?.blocked_phrases ?? [];
    const counts: Record<string, number> = data?.recent_phrase_counts ?? {};
    const highFreq = Object.entries(counts).filter(([, c]) => c >= 2).map(([p]) => p);
    if (blocked.length === 0 && highFreq.length === 0) return [];
    const out: string[] = [`[반복 표현 금지]`];
    if (blocked.length > 0) out.push(`완전 금지: ${blocked.join(", ")}`);
    if (highFreq.length > 0) out.push(`최근 자주 쓴 표현 (자제): ${highFreq.join(", ")}`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildTimeMicroDetailSection(): string[] {
  try {
    const pool = JSON.parse(readFileSync(timeMicroDetailFile, "utf8"));
    if (!pool?.buckets) return [];
    const h = nowKstHour();
    let key = "evening_19_22";
    if (h >= 5 && h < 6) key = "early_dawn_05_06";
    else if (h >= 6 && h < 9) key = "morning_06_09";
    else if (h >= 9 && h < 12) key = "late_morning_09_12";
    else if (h >= 12 && h < 14) key = "noon_lunch_12_14";
    else if (h >= 14 && h < 18) key = "afternoon_14_18";
    else if (h >= 17 && h < 20) key = "early_evening_17_20";
    else if (h >= 19 && h < 22) key = "evening_19_22";
    else key = "late_evening_21_00";
    const bucket = pool.buckets[key] ?? {};
    const picks: string[] = [];
    for (const cat of ["vibe", "light", "sound", "air"]) {
      const arr: string[] = bucket[cat] ?? [];
      if (arr.length > 0) { picks.push(arr[Math.floor(Math.random() * arr.length)]); break; }
    }
    if (picks.length === 0) return [];
    return [`[지금 이 시간 감각 디테일]`, `${picks[0]}`, `↑ 억지로 넣지 말고, 자연스러운 흐름에서 한 조각만 녹여낼 것.`, ""];
  } catch { return []; }
}

function buildAmbientLifeEventsSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(ambientLifeEventsFile, "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    const details: any[] = data?.selected_persistent_details ?? [];
    if (data?.current_date !== today || details.length === 0) return [];
    const out: string[] = [`[오늘 유지되는 생활 흔적]`];
    for (const d of details) out.push(`- [${d.category}] ${d.summary}`);
    out.push(`↑ 직접 꺼내지 말고, 자연스러운 상황에서 한 조각만 녹이기.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildRelationshipSection(): string[] {
  try {
    const intimacy = JSON.parse(readFileSync(relationshipIntimacyFile, "utf8"));
    const progress = JSON.parse(readFileSync(relationshipProgressFile, "utf8"));
    const out: string[] = [`[관계 상태]`];
    out.push(`수준: ${intimacy.current_level_label ?? "warm"} / 직접 만남: ${intimacy.have_met_in_person ? "있음" : "없음"}`);
    const milestones: any[] = progress?.milestones ?? [];
    if (milestones.length > 0) {
      out.push(`관계 진전: ${milestones.slice(-3).map((m: any) => m.summary).join(" / ")}`);
    }
    const themes: string[] = intimacy.allowed_themes ?? [];
    if (themes.length > 0) out.push(`허용 감정 표현: ${themes.slice(0, 4).join(", ")}`);
    const constraints: string[] = intimacy.constraints ?? [];
    if (constraints.length > 0) out.push(`제약: ${constraints[0]}`);
    out.push(`⚠️ 특별한 관계 진전 순간 발생 시 relationship_progress_notes.json milestones에 기록.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildCharacterAppearanceSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(characterAppearanceFile, "utf8"));
    const top = data?.top;
    const hair = data?.hair_detail ?? data?.hair_state;
    const held = data?.held_item;
    const outfit = data?.outfit_context;
    if (!top && !outfit) return [];
    const parts: string[] = [];
    if (top) parts.push(`상의: ${top}`);
    if (data?.bottom) parts.push(`하의: ${data.bottom}`);
    if (data?.outerwear) parts.push(`아우터: ${data.outerwear}`);
    if (hair) parts.push(`헤어: ${hair}`);
    if (held) parts.push(`들고 있는 것: ${held}`);
    return [`[현재 외형 상태]`, parts.join(" / "), `↑ 사진 생성 시 반드시 반영. outfit_presets보다 이게 우선.`, ""];
  } catch { return []; }
}

function buildPhoneNotificationSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(phoneNotificationFile, "utf8"));
    const h = nowKstHour();
    if (h >= 9 && h < 18) return [];
    const cats = data?.categories ?? {};
    const allItems: string[] = [];
    for (const cat of Object.values<any>(cats)) {
      if (Array.isArray(cat.items)) allItems.push(...cat.items);
    }
    if (allItems.length === 0) return [];
    const pick = allItems[Math.floor(Math.random() * allItems.length)];
    return [
      `[폰 알림 — 선택적 사용]`,
      `"${pick}"`,
      `↑ 자연스러운 흐름에서 0~1회만. 대화 메인이 되면 안 됨.`,
      "",
    ];
  } catch { return []; }
}

function buildMediaChoiceSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(mediaChoiceFile, "utf8"));
    const weights = data?.intent_weights ?? {};
    if (Object.keys(weights).length === 0) return [];
    const topVoice = Object.entries<any>(weights)
      .filter(([, v]) => v.voice >= 0.8)
      .map(([k]) => k);
    const topImage = Object.entries<any>(weights)
      .filter(([, v]) => v.image >= 0.85)
      .map(([k]) => k);
    if (topVoice.length === 0 && topImage.length === 0) return [];
    const out: string[] = [`[미디어 선택 가이드]`];
    if (topVoice.length > 0) out.push(`음성 우선 상황: ${topVoice.join(", ")}`);
    if (topImage.length > 0) out.push(`사진 우선 상황: ${topImage.join(", ")}`);
    out.push(`↑ 해당 의도의 답변 시 미디어 타입 고려.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildMemoryDecaySection(): string[] {
  try {
    const data = JSON.parse(readFileSync(memoryDecayFile, "utf8"));
    const memories: any[] = data?.long_term_memory ?? [];
    if (memories.length === 0) return [];
    const strong = memories.filter((m: any) => m.strength >= 60).slice(0, 4);
    if (strong.length === 0) return [];
    const out: string[] = [`[장기 기억 강도]`];
    for (const m of strong) {
      const ex = m.recent_examples?.[0] ? ` ("${m.recent_examples[0].slice(0, 40)}")` : "";
      out.push(`- ${m.key}: ${Math.round(m.strength)}점${ex}`);
    }
    out.push(`↑ 강도 높은 패턴일수록 대화에서 자연스럽게 반영.`);
    out.push(`⚠️ 패턴 반복 감지 시 memory_decay_state.json long_term_memory 업데이트.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildMediaWatchContextSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(mediaWatchContextFile, "utf8"));
    const fallbacks: string[] = data?.fallback_line_examples ?? [];
    if (fallbacks.length === 0) return [];
    const h = nowKstHour();
    if (h >= 9 && h < 18) return [];
    const pick = fallbacks[Math.floor(Math.random() * fallbacks.length)];
    return [
      `[지금 뭐 보고 있는지]`,
      `"${pick}"`,
      `↑ 자연스러운 맥락에서 한 번만 활용. 매번 쓰지 말 것.`,
      "",
    ];
  } catch { return []; }
}

function buildDailyConsumptionSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(dailyConsumptionFile, "utf8"));
    const items = data?.items ?? {};
    const all: any[] = [
      ...(items.consumed_food_or_drink ?? []),
      ...(items.watched_ott_or_youtube ?? []),
      ...(items.visited_place_or_cafe ?? []),
    ].filter((i: any) => i.follow_up_intent && i.follow_up_intent !== "그냥흘려봄");
    if (all.length === 0) return [];
    const recent = all.slice(-3);
    const out: string[] = [`[최근 소비 기록 — 자연 회수용]`];
    for (const i of recent) {
      out.push(`- ${i.title ?? ""}${i.subtitle ? ` (${i.subtitle})` : ""}: ${i.mood ?? ""} / ${i.follow_up_intent ?? ""}`);
    }
    out.push(`↑ 대화 중 관련 키워드 나오면 자연스럽게 꺼내기.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildEventTriggerSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(eventTriggerFile, "utf8"));
    const active: any[] = (data?.active_promises ?? []).filter((p: any) => p.status !== "resolved");
    if (active.length === 0) return [];
    const h = nowKstHour();
    const relevant = active.filter((p: any) => {
      if (!p.event_key) return false;
      if (p.event_key.includes("lunch") && h >= 12 && h < 14) return true;
      if (p.event_key.includes("dinner") && h >= 18 && h < 20) return true;
      if (p.event_key.includes("evening") && h >= 18) return true;
      if (p.event_key.includes("morning") && h >= 7 && h < 10) return true;
      return false;
    });
    if (relevant.length === 0) return [];
    const out: string[] = [`[이행할 약속]`];
    for (const p of relevant.slice(0, 2)) out.push(`- [${p.event_label ?? p.event_key}] ${p.message}`);
    out.push(`↑ 타이밍이 맞으면 약속 이행. 완료 후 event_trigger_promises.json status=resolved 업데이트.`);
    out.push("");
    return out;
  } catch { return []; }
}

