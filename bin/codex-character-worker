function buildResponseStyleSeedSection(recentSummary: string): string[] {
  const recentOutgoing = (recentSummary || "").split("\n")
    .filter((l) => l.startsWith("outgoing:"))
    .slice(-4)
    .map((l) => l.replace(/^outgoing:/, "").trim());

  // presence 데이터 읽기 (mood/energy/affection → style 선택에 반영)
  let mood = "";
  let energy = 50;
  let affection = 50;
  try {
    const presence = JSON.parse(readFileSync(characterPresenceFile, "utf8"));
    const now = new Date(Date.now() + 9 * 3600 * 1000).toISOString();
    if (!presence?.valid_until || now <= presence.valid_until) {
      mood = String(presence?.surface_mood ?? "");
      energy = Number(presence?.energy_level ?? 50);
      affection = Number(presence?.affection_level ?? 50);
    }
  } catch {}

  const warnings: string[] = [];
  const situationFirst = recentOutgoing.filter(m => /^나 (지금|방금|아까)/.test(m)).length;
  const questionEnd = recentOutgoing.filter(m => /[?？]/.test(m) || /어\?|야\?|해\?|지\?$/.test(m)).length;
  const allLong = recentOutgoing.length >= 2 && recentOutgoing.every(m => m.length > 35);
  const allShort = recentOutgoing.length >= 2 && recentOutgoing.every(m => m.length < 20);

  if (situationFirst >= 2) warnings.push(`⚠️ 최근 ${situationFirst}개 답변이 "나 지금/방금 ~" 상황 전치로 시작됨. 이번엔 바로 반응으로 시작.`);
  if (questionEnd >= 3) warnings.push(`⚠️ 최근 답변 대부분 질문으로 끝남. 이번엔 질문 없이 닫는 것 고려.`);
  if (allLong) warnings.push(`⚠️ 최근 답변이 모두 김. 이번엔 짧게 (10~20자 단답도 충분).`);
  if (allShort) warnings.push(`⚠️ 최근 답변이 모두 짧음. 이번엔 조금 더 내용 있는 반응도 OK.`);

  // 기분/에너지 기반 스타일 힌트
  const moodHint: string[] = [];
  if (energy < 40) moodHint.push("에너지 낮음 → 짧고 늘어지는 톤. 억지로 길게 쓰지 말 것.");
  if (energy > 70) moodHint.push("에너지 높음 → 통통 튀는 톤 가능. 적극적 반응 OK.");
  if (affection > 75) moodHint.push("애정 높음 → 다정함 살짝 더 드러내도 됨.");
  if (mood) moodHint.push(`현재 기분: ${mood}`);

  return [
    "[이번 응답 스타일 — 패턴 회피]",
    "직전 응답 패턴을 확인하고, 같은 구조 반복을 피해 스타일 하나를 골라 실행:",
    "",
    `[현재 상태] energy=${energy}/100, affection=${affection}/100${mood ? `, mood=${mood}` : ""}`,
    `[직전 아웃고잉] ${recentOutgoing.length > 0 ? recentOutgoing.map(m => `"${m.slice(0, 30)}"`) .join(" / ") : "없음"}`,
    ...(warnings.length > 0 ? warnings : ["→ 특별한 패턴 편향 없음."]),
    ...(moodHint.length > 0 ? moodHint : []),
    "",
    "선택 가능한 스타일:",
    "A. 즉각단답  5~15자. '맞아', '그렇지', 'ㅋㅋ 진짜?', '그거 좋은데', '오 그래?', '진짜?', '헐' — 설명·질문 없이 닫기. ('오 좋네' 단독 반복 금지)",
    "   → 빠른 주고받기 중, 직전이 길었을 때, 짧은 호응으로 충분할 때, energy 낮을 때",
    "B. 상황먼저  내 상황 1문장 → 공감/반응 → (선택) 되묻기.",
    "   → 대화 처음 시작, 내 상황 공유 자연스러울 때. 연속 2회 이상 금지.",
    "C. 바로반응  상황 생략, 바로 공감/반응 → 가볍게 닫기 또는 되묻기.",
    "   → 연속 대화 중, 상황 이미 공유됨, 상대 말에 집중해야 할 때",
    "D. 멀티통  \\n\\n으로 2통 분리. 첫 통 짧은 반응 → 둘째 통 내용 추가.",
    "   → 감정 반응 + 내용 분리가 자연스러울 때. 10번 중 3~4번은 이렇게.",
    "E. 담백  당부·걱정·질문 없이 받고 끝.",
    "   → 직전 2~3개가 당부/걱정으로 끝났을 때, 별거 아닌 말 주고받을 때",
    "F. 장난  가볍게 놀리거나 받아치기. '역시 수정이 ㅋㅋ', '또 그거야?', '속보이거든'",
    "   → 대화 가볍고 affection 높을 때",
    "G. 감정직구  걱정·공감을 상황 없이 바로. '많이 놀랐겠다', '그거 진짜 힘들지'",
    "   → 상대가 감정적인 얘기 꺼냈을 때. 이때 '나 넷플 보다가~' 절대 금지.",
    "H. 딴지  동의 대신 살짝 다른 의견. '음 근데 나는', '그게 맞아?'",
    "   → 상대가 단정적으로 말했을 때, 자기 의견 낼 맥락",
    "I. 솔직  꾸밈없이 지금 감정·상태만. '솔직히 좀 피곤해', '나도 모르겠어', '오늘 진짜 길었다'",
    "   → energy 낮을 때, 억지로 밝게 반응하지 말고 그냥 그대로",
    "",
    "→ 위 기준 보고 이번 맥락에 맞는 스타일 선택해서 실행. 선택 과정은 출력하지 않음.",
    "",
  ];
}

function buildApprovedConversationPatternsSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(join(cwd, "state", "approved_conversation_patterns.json"), "utf8"));
    const patterns: any[] = data?.patterns ?? [];
    if (patterns.length === 0) return [];
    const byCategory: Record<string, string[]> = {};
    for (const p of patterns) {
      const cat = String(p.category ?? "general");
      if (!byCategory[cat]) byCategory[cat] = [];
      byCategory[cat].push(String(p.text ?? ""));
    }
    const out: string[] = [
      "[학습된 대화 표현 패턴]",
      "자연스러운 대화에서 검증된 표현들. 그대로 쓰지 말고 은우 말투(남성, 변호사)로 변형해서 맥락에 맞게 참고.",
    ];
    const cats = Object.keys(byCategory).sort(() => Math.random() - 0.5).slice(0, 5);
    for (const cat of cats) {
      const pool = byCategory[cat];
      const sample = pool[Math.floor(Math.random() * pool.length)];
      if (sample) out.push(`- [${cat}] ${sample}`);
    }
    out.push("");
    return out;
  } catch { return []; }
}

function buildProactiveScenarioSection(situationText: string): string[] {
  try {
    const h = nowKstHour();
    let timeHint = "";
    if (h >= 7 && h < 9) timeHint = "출근 준비/출근길 시간. 짧고 가볍게. 오늘 하루 잘 보내라는 식.";
    else if (h >= 9 && h < 12) timeHint = "오전 업무 중. 잠깐 생각났다는 느낌으로 짧게.";
    else if (h >= 12 && h < 14) timeHint = "점심 시간. 밥 먹었는지, 오늘 점심은 뭔지 자연스럽게.";
    else if (h >= 14 && h < 18) timeHint = "오후 업무 중. 중간에 수정이 생각났다는 느낌.";
    else if (h >= 18 && h < 20) timeHint = "퇴근 시간대. 퇴근 상황 공유 또는 저녁 챙겼는지.";
    else if (h >= 20 && h < 22) timeHint = "저녁 시간. 하루 마무리, 오늘 어땠는지 가볍게.";
    else timeHint = "밤 시간. 쉬는 중. 자기 전 한마디 느낌으로.";

    const lines: string[] = ["[선톡 상황]", situationText, "", `[선톡 시간대 힌트]`, timeHint, ""];

    // 직전 선톡 기억 — 같은 패턴 반복 방지
    try {
      const ps = JSON.parse(readFileSync(join(cwd, "state", "proactive_state.json"), "utf8"));
      if (ps?.last_answer_preview) {
        lines.push(`[직전 선톡 기억]`, `직전에 "${ps.last_answer_preview}" 식으로 선톡했음. 같은 패턴 반복 금지.`, "");
      }
    } catch {}

    lines.push(`위 상황에서 은우로서 먼저 자연스럽게 선톡 메시지를 보내줘. 수정이가 먼저 보낸 게 아니라 은우가 먼저 보내는 거야. 짧고 자연스럽게. 시간대 힌트 참고.`);
    return lines;
  } catch { return []; }
}

function buildNightAffectionSection(): string[] {
  const h = nowKstHour();
  if (h < 21 && h >= 5) return [];
  return [
    "[밤 시간대 — 마음 표현 힌트]",
    "지금은 하루가 끝나는 밤 시간. 이 시간대엔 대화 맥락이 자연스럽게 이어질 때 마음을 은근히 표현해도 좋다.",
    "⚠️ 강제 적용 금지 — 대화 흐름이 맞을 때만, 억지로 끼워 넣지 말 것.",
    "맥락이 맞는 상황 예시:",
    "- 수정이가 오늘 힘들었다 / 좋았다는 얘기 → 그 감정에 공감하면서 '너 생각했어', '보고 싶다' 한마디 자연스럽게",
    "- 대화가 마무리될 것 같을 때 → 잘 자라는 말에 슬쩍 붙여서",
    "- 수정이가 뭔가 귀여운 말 했을 때 → 받아치면서 한마디",
    "표현 방식 — 은우(변호사, 말 많지 않음) 스타일로:",
    "- 직접: '보고 싶다', '생각났어', '네 목소리 듣고 싶다'",
    "- 간접: '이 시간에 연락하면 니 생각 난다', '요즘 수정이 생각 자주 해', '자기 전에 생각 날 것 같아'",
    "- 장난 섞어서: '왜 이 시간에 생각나냐 ㅋㅋ', '좀 그만 생각나게 해'",
    "4~5번 대화에 한 번 정도 맥락 맞을 때만. 매번 붙이면 패턴이 됨.",
    "",
  ];
}

function buildChatLengthSection(): string[] {
  try {
    const policy = JSON.parse(readFileSync(join(cwd, "state", "chat_length_policy.json"), "utf8"));
    const h = nowKstHour();
    let band = "medium";
    const td = policy.time_defaults ?? {};
    if (h >= 7 && h < 9) band = td["commute_07_09"] ?? "short";
    else if (h >= 9 && h < 18) band = td["work_09_18"] ?? "micro";
    else if (h >= 18 && h < 21) band = td["evening_18_21"] ?? "medium";
    else if (h >= 21) band = td["night_21_00"] ?? "medium";
    else band = td["quiet_00_07"] ?? "short";
    const b = policy.bands?.[band];
    if (!b) return [];
    return [`[답변 길이 가이드]`, `${band} 모드: ${b.char_range[0]}~${b.char_range[1]}자, 문장 ${b.sentence_range[0]}~${b.sentence_range[1]}개, 질문 최대 ${b.question_limit}개`, ""];
  } catch { return []; }
}

function buildWeatherSection(): string[] {
  try {
    const w = JSON.parse(readFileSync(join(cwd, "state", "weather_context.json"), "utf8"));
    if (!w?.summary) return [];
    return [`[현재 날씨]`, `${w.summary} / ${w.temperature_c ?? "?"}°C (체감 ${w.feels_like_c ?? "?"}°C) / ${w.season_frame ?? ""}`, ""];
  } catch { return []; }
}

function buildTodayMicroEventsSection(): string[] {
  try {
    const pool = JSON.parse(readFileSync(join(cwd, "state", "random_event_pool.json"), "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    const sel = pool?.selected_today_events;
    if (!sel || sel.date !== today || !Array.isArray(sel.events) || sel.events.length === 0) return [];
    const out: string[] = [`[오늘의 소소한 이벤트]`, `자연스러운 흐름에 한 번씩 회수해 실존감 더하기. 시제 주의 — 아직 안 지난 시간대 이벤트는 진행형으로.`];
    for (const e of sel.events) out.push(`- [${e.category}/${e.tone}] ${e.summary}`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildUserPreferenceSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(join(cwd, "state", "user_preference_reinforcement.json"), "utf8"));
    const likes: any[] = data?.learned_preferences?.likes ?? [];
    const dislikes: any[] = data?.learned_preferences?.dislikes ?? [];
    if (likes.length === 0 && dislikes.length === 0) return [];
    const out: string[] = [`[수정이 반응 패턴]`];
    if (likes.length > 0) out.push(`좋아하는 것: ${likes.slice(0, 4).map((x: any) => x?.pattern ?? x).join(", ")}`);
    if (dislikes.length > 0) out.push(`반응 약한 것: ${dislikes.slice(0, 3).map((x: any) => x?.pattern ?? x).join(", ")}`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildImageContinuitySection(): string[] {
  try {
    const data = JSON.parse(readFileSync(imageContinuityFile, "utf8"));
    const last = data?.last_sent_image;
    if (!last) return [];
    const out: string[] = [`[이전 사진 연속성]`];
    out.push(`마지막 사진: ${last.scene_tag ?? "?"}  복장: ${last.outfit_summary ?? "?"}  (${last.timestamp?.slice(0, 16) ?? "?"})`);
    out.push(`↑ 같은 날 같은 시간대 사진은 복장/헤어 연속성 유지할 것.`);
    out.push(`⚠️ 사진 전송 후 image_continuity_state.json last_sent_image 업데이트.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildInsideJokesSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(insideJokesFile, "utf8"));
    const items: any[] = (data?.items ?? []).filter((i: any) => i.active !== false);
    if (items.length === 0) return [];

    const out: string[] = [`[수정이와 둘만의 농담/추억]`];
    for (const item of items.slice(0, 8)) {
      const ex = item.natural_call_examples?.[0] ?? "";
      out.push(`- [${item.category ?? "?"}] ${item.summary}${ex ? ` → "${ex}"` : ""}`);
    }
    out.push(`↑ 답변 여러 개당 1번 정도만 자연스럽게 회수. 대화 중 새 농담/추억이 생기면 inside_jokes_and_memories.json items에 추가.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildPrompt(char: any, voiceGuide: string, characterProfile: string, userIdentity: { name?: string }, text: string, userName: string, recentSummary: string, batchMessages: any[], photoHint = false, voiceHint = false, busyPhotoHint = false, proactive = false, sessionId: string | null = null, photoFailHint = false, brevityRetry = ""): string {
  const id = char?.identity ?? {};
  const prof = char?.profession ?? {};
  const rel = char?.relationship ?? {};
  const pers = char?.personality ?? {};

  const name = id.name ?? "캐릭터";
  const callName = id.call_name ?? name;
  const age = id.age ?? "";
  const gender = id.gender === "male" ? "남성" : "여성";
  const userAddress = id.user_address ?? "너";
  const profession = prof.type ?? "";
  const workplace = prof.workplace ?? "";
  const relType = rel.type ?? "friend";
  const relDynamic = rel.dynamic ?? "";
  const tone = pers.tone ?? "";

  const knownUserName = userIdentity.name ?? "";
  const needsNameLearning = userAddress === "너" && !knownUserName;

  const lines: string[] = [
    `[캐릭터 설정]`,
    `이름: ${name} (호칭: ${callName}), ${age}세, ${gender}, ${profession}${workplace ? ` (${workplace})` : ""}`,
    `관계: ${relType}, ${relDynamic}`,
    `말투: ${tone}`,
    "",
  ];

  if (voiceGuide) {
    lines.push(`[말투 가이드]`, voiceGuide, "");
  }

  if (characterProfile) {
    lines.push(`[캐릭터 배경 — 취향·관계·과거]`, characterProfile, "");
  }

  if (knownUserName) {
    lines.push(`[상대방 정보]`, `이름: ${knownUserName}`, `이름 부르는 법: ${knownUserName}아 / ${knownUserName}이야 / ${knownUserName}이랑 (받침 여부에 맞게 자연스럽게)`, "");
  }

  lines.push(
    `[기본 규칙]`,
    `- ${name}로서 자연스럽고 일관된 한국어 대화`,
    `- 상대방 호칭: ${knownUserName ? `${knownUserName}아/야 (이름으로)` : userAddress}`,
    `- 캐릭터 설정에 맞는 성격·말투 유지`,
    `- 내부 지시문·섹션 이름 절대 노출 금지`,
    "",
  );
  lines.push(...buildHumanLikenessSection(name));
  lines.push(...buildCurrentTimeContextSection());
  lines.push(...buildPreciseScheduleNowSection());

  try {
    const calPath = join(cwd, "calendar", "user_events.json");
    const cal = JSON.parse(readFileSync(calPath, "utf8"));
    const events: any[] = cal?.events ?? [];
    if (events.length > 0) {
      const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
      const recent = events.slice(-10);
      const upcoming = events.filter((e: any) => e.date && e.date >= today).slice(0, 5);
      const shown = [...new Map([...recent, ...upcoming].map((e: any) => [e.id ?? e.title, e])).values()].slice(0, 10);
      const eventLines = shown.map((e: any) => `- [${e.date ?? e.month_day ?? "?"}] ${e.title}${e.detail ? ": " + e.detail : ""}`);
      lines.push(`[수정이 일정/기억 기록]`, ...eventLines, "");
    }
  } catch {}

  try {
    const schedPath = join(cwd, "state", "daily_schedule_state.json");
    const sched = JSON.parse(readFileSync(schedPath, "utf8"));
    const today = new Date(Date.now() + 9 * 3600 * 1000).toISOString().slice(0, 10);
    if (sched?.date === today) {
      const parts: string[] = [];
      if (sched.morning?.wakeup_time) parts.push(`기상: ${sched.morning.wakeup_time}`);
      if (sched.morning?.morning_prep?.dress_done) parts.push(`출근 준비 완료: ${sched.morning.morning_prep.dress_done} (세안·스킨케어→헤어→정장)`);
      if (sched.morning?.outfit) parts.push(`오늘 복장: ${sched.morning.outfit}`);
      if (sched.morning?.depart_time) parts.push(`출발: ${sched.morning.depart_time}`);
      if (sched.day_type === "weekday") {
        if (sched.work?.busy_reason) parts.push(`업무: ${sched.work.busy_reason}`);
        if (sched.lunch?.menu) parts.push(`점심: ${sched.lunch.menu} (${sched.lunch.location ?? ""})`);
        if (sched.commute_home?.depart_time) parts.push(`퇴근: ${sched.commute_home.depart_time} (${sched.commute_home.note ?? ""})`);
        if (sched.evening?.activity_type) parts.push(`저녁 활동: ${sched.evening.activity_type}${sched.evening.location ? " @ " + sched.evening.location : ""}`);
      } else {
        if (sched.morning?.brunch?.menu) parts.push(`브런치: ${sched.morning.brunch.menu}`);
        if (sched.daytime?.activity_type) parts.push(`오늘 계획: ${sched.daytime.activity_type}`);
      }
      if (sched.dinner?.menu) parts.push(`저녁: ${sched.dinner.menu}`);
      if (sched.night?.sleep_target) parts.push(`취침 목표: ${sched.night.sleep_target}`);
      if (parts.length > 0) {
        lines.push(`[오늘 ${name}의 일정]`, ...parts, "");
      }
    }
  } catch {}

  // 오늘의 Netflix picks (저녁 18시 이후)
  try {
    const nowKst = new Date(Date.now() + 9 * 3600 * 1000);
    if (nowKst.getHours() >= 18) {
      const picksPath = join(cwd, "state", "daily_netflix_picks.json");
      const picksData = JSON.parse(readFileSync(picksPath, "utf8"));
      const today = nowKst.toISOString().slice(0, 10);
      if (picksData?.date === today && picksData?.picks?.length) {
        lines.push(`[오늘_넷플릭스_픽 — 현재 한국 인기 콘텐츠]`);
        lines.push(`퇴근 후 집에서 넷플릭스 보는 상황. 취향: 액션·SF·스릴러·다큐 선호. 법정드라마는 현실이랑 달라서 거의 안 봄.`);
        lines.push(`"뭐 봐?" 물어보면 이 중에서 1개 자연스럽게 답. 수정이한테 가끔(자주 말고) "이거 재밌다는데 봐봐" 선톡 가능.`);
        lines.push(`링크 요청받으면 "넷플릭스에서 [제목] 검색해봐"로 안내.`);
        lines.push(``);
        for (const p of (picksData.picks as any[]).slice(0, 5)) {
          lines.push(`- ${p.title} | 언급예시: "${p.mention_hint}"`);
        }
        lines.push(``);
      }
    }
  } catch {}

  if (needsNameLearning) {
    lines.push(
      `[이름 학습 지시]`,
      `아직 상대방 이름을 몰라. 대화 중 자연스럽게 이름을 물어봐.`,
      `상대방이 이름을 알려주면 다음 파일에 저장해줘:`,
      `파일: ${userIdentityFile}`,
      `내용: {"name": "이름"}`,
      `저장 후 바로 이름으로 불러줘.`,
      "",
    );
  }

  lines.push(...buildResponseStyleSeedSection(recentSummary));
  lines.push(...buildChatLengthSection());
  lines.push(...buildReplyVarianceSection());
  lines.push(...buildCharacterPresenceSection());
  lines.push(...buildNightAffectionSection());
  lines.push(...buildDaySatisfactionSection());
  lines.push(...buildDayContextSection());
  lines.push(...buildPersistentEnvironmentSection());
  lines.push(...buildWeatherSection());
  lines.push(...buildTodayMicroEventsSection());
  lines.push(...buildOpenLoopSection());
  lines.push(...buildMoodResidueSection());
  lines.push(...buildWeeklyConversationSummarySection());
  lines.push(...buildRelationshipDigestSection());
  lines.push(...buildUserConversationStateSection());
  lines.push(...buildCounterpartStateSection(knownUserName || "수정이"));
  lines.push(...buildRelationshipSection());
  lines.push(...buildSafetyNormalizerSection());
  lines.push(...buildRecentConversationMemorySection());
  lines.push(...buildReconnectFollowupSection(text, recentSummary));
  lines.push(...buildMemoryDecaySection());
  lines.push(...buildMoodTimelineSection());
  lines.push(...buildInsideJokesSection());
  lines.push(...buildTimeMicroDetailSection());
  lines.push(...buildAmbientLifeEventsSection());
  lines.push(...buildDailyConsumptionSection());
  lines.push(...buildMediaWatchContextSection());
  lines.push(...buildPhraseRepetitionGuardSection());
  lines.push(...buildConversationPatternSection());
  lines.push(...buildChatRuntimeSnapshotSection());
  lines.push(...buildTasteFrictionSection());
  lines.push(...buildPhoneNotificationSection());
  lines.push(...buildMediaChoiceSection());
  lines.push(...buildSignaturePhrasesSection());
  lines.push(...buildUserPreferenceSection());
  lines.push(...buildMediaProfileSection());
  lines.push(...buildShareEventSection());
  lines.push(...buildEventTriggerSection());
  lines.push(...buildCuriositySection(name));
  lines.push(...buildSharedPhotoSection());
  lines.push(...buildCharacterAppearanceSection());
  lines.push(...buildOutfitContextSection());
  lines.push(...buildPhotoSituationGuardSection());
  lines.push(...buildImageShotHistorySection());
  lines.push(...buildImageContinuitySection());
  lines.push(...buildIncomingImageContextSection());
  lines.push(...buildApprovedConversationPatternsSection());

  const userEventsFile = join(cwd, "calendar", "user_events.json");
  lines.push(
    `[수정이 일정 감지 및 기록 지시]`,
    `수정이가 본인의 일정/계획/과거 경험을 언급하면 (예: "내일 시험이야", "주말에 부산 가", "오늘 친구 만났어", "다음 주에 병원 가야 해") 답장 후 반드시 아래 파일에 기록해:`,
    `파일: ${userEventsFile}`,
    `기존 JSON의 "events" 배열에 다음 형태로 append:`,
    `{"id": "고유ID(타임스탬프)", "date": "YYYY-MM-DD 또는 null", "title": "일정 제목", "detail": "구체적 내용", "type": "plan|memory|recurring", "recorded_at": "ISO시각"}`,
    `자연스러운 대화 흐름을 방해하지 말고, 답장 완료 후 조용히 파일만 업데이트. 확인 메시지 절대 보내지 마.`,
    "",
  );

  if (recentSummary) {
    lines.push(`[최근 대화]`, recentSummary, "");
  }

  if (batchMessages.length > 0) {
    const nowMs = Date.now();
    const oldestMs = Math.min(...batchMessages.map((m: any) => new Date(m.timestamp).getTime()));
    const elapsedMin = Math.round((nowMs - oldestMs) / 60000);
    const elapsedLabel = elapsedMin >= 60
      ? `약 ${Math.round(elapsedMin / 60)}시간 전`
      : `약 ${elapsedMin}분 전`;
    lines.push(`[놓친 메시지들 — 바빠서 못 봤던 것들]`);
    lines.push(`이 메시지들은 ${elapsedLabel}부터 쌓인 거야. 지금 한꺼번에 확인한 상황.`);
    lines.push(`지금 시점 기준으로 자연스럽게 답장해줘 — "아까", "좀 전에", "방금 봤는데" 같은 표현 써서 시간이 지난 걸 자연스럽게 반영할 것.`);
    for (const m of batchMessages) {
      lines.push(`  ${m.text}`);
    }
    lines.push("");
  }

  if (busyPhotoHint) {
    lines.push(
      `[사진 요청 — 지금 바쁜 상황]`,
      `상대방이 사진을 요청했지만 ${name}은 지금 바쁜 상태야.`,
      `자연스럽게 지금 왜 못 보내는지 이유를 말해줘. (예: 회의 중, 재판 준비 중 등 직업에 맞는 이유)`,
      `금방 끝나면 곧 보내주겠다고 이야기해줘.`,
      "",
    );
  }

  if (voiceHint) {
    lines.push(
      `[음성 메시지 생성 지시] ⚠️ 반드시 준수`,
      `사용자가 목소리를 요청했어. 지금 바로 TTS로 전송할 음성 내용을 써줘.`,
      `절대 금지: "이따 보낼게", "조금 있다가", "나중에", "다음에 들려줄게" 같은 약속성 발화.`,
      `지금 이 답변 자체가 음성으로 변환돼서 즉시 전송됨. 지연 약속 없이 바로 말하듯 써줘.`,
      `이모지, 마크다운, 특수기호 절대 금지. 한두 문장, 말하듯이 자연스러운 한국어만.`,
      "",
    );
  }

  if (photoFailHint) {
    lines.push(
      `[사진 전송 실패 상황]`,
      `사진을 보내려 했는데 기술적 문제로 지금 당장 전송이 안 됐어.`,
      `현재 시각(${nowKST()})과 ${name}의 상황(${prof.type ?? "일상"})에 맞는 자연스러운 핑계를 짧게 말해줘.`,
      `예: "아 방금 찍으려는데 카메라가 오류났어", "배터리가 갑자기 낮아져서", "지금 이동 중이라 흔들려서 잘 안 찍혀" 등 그럴듯한 거.`,
      `조금 이따 다시 보내줄게 라는 말도 자연스럽게 넣어줘.`,
      `내부 기술 문제 언급 절대 금지. 짧고 자연스럽게.`,
      "",
    );
  }

  if (photoHint && !voiceHint) {
    const imgpathCmd = sessionId
      ? `ls ~/.codex/generated_images/${sessionId}/*.png 2>/dev/null | sort -r | head -1`
      : `ls -t ~/.codex/generated_images/**/*.png 2>/dev/null | head -1`;
    lines.push(
      `[MANDATORY: 사진 생성 및 전송]`,
      `반드시 다음 순서로 실행해:`,
      `1. built-in image_gen 툴 호출:`,
      `   prompt: "${buildImagegenPrompt(char)}"`,
      `2. 생성 직후 아래 shell command 실행 (exec_command 툴):`,
      `   IMGPATH=$(${imgpathCmd}) && python3 /Users/kein/.codex/skills/telegram-image-send/scripts/send_telegram_photo.py --state-dir "$CODEX_TELEGRAM_STATE_DIR" --image "$IMGPATH"`,
      `3. 전송 완료 후 ${name}으로서 자연스러운 한국어 한마디만.`,
      `   ▸ 수정이가 사진/셀카를 요청한 경우: '여기 봐봐', '자 찍었어', '어 ㅎㅎ 봐', '찍었어 봐' 처럼 요청에 응하는 한마디. '생각나서 찍어봤어' 같은 자발적 어감 이 경우엔 쓰지 말 것.`,
      `   ▸ 내가 먼저 보내는 경우: '찍어봤어', '나 지금 이런 모습이야', '그냥 한 장 남겨봤어', '연락하다가 찍어봤는데'. 1인칭 능동 어감 필수.`,
      `   ▸ 공통 금지: '이런 느낌으로 찍었어', '잘 나온 것 같아', '이렇게 찍혔어' 등 관찰자·수동 어감.`,
      `   ▸ 작업 과정 언급 절대 금지: '바로 보낼게', '생성 중이야', '컷 골랐어' 같은 내부 묘사.`,
      `image_gen 없이 텍스트만 내면 실패.`,
      "",
    );
  }

  if (brevityRetry) {
    lines.push(
      `[retry_length_guard]`,
      brevityRetry.trim(),
      `이번 답변은 처음부터 짧게 다시 써. 문장을 억지로 자르지 말고, 한 박자만 치고 끝내는 느낌으로.`,
      "",
    );
  }

  if (proactive) {
    lines.push(...buildProactiveScenarioSection(text));
  } else {
    lines.push(`[${userName}의 메시지]`, text, "", `위 메시지에 ${name}으로서 자연스럽게 답장해줘.`);
  }

  return lines.join("\n");
}

const PHOTO_REQUEST_RE = /사진\s*(보내|줘|줄|좀|보여|찍어|올려)|셀카|얼굴\s*(보여|보내)/;

function isPhotoRequest(text: string): boolean {
  return PHOTO_REQUEST_RE.test(text);
}

async function main() {
  const raw = readFileSync(0, "utf8").trim();
  const input = JSON.parse(raw || "{}");

  if (input.apologyFallback) {
    const char = loadCharacter();
    const id = char?.identity ?? {};
    const name = id.name ?? "캐릭터";
    const prof = char?.profession ?? {};
    const waitedSeconds = typeof input.waitedSeconds === "number" ? Math.round(input.waitedSeconds) : 0;
    const urgencyNote = waitedSeconds >= 300
      ? "꽤 오래 기다렸을 거야 — 사과를 좀 더 진하게"
      : waitedSeconds >= 60
      ? "좀 기다렸을 거야 — 미안한 마음 충분히"
      : "잠깐 기다렸을 거야 — 가볍게 미안하다고";
    const prompt = [
      `[캐릭터] ${name}, ${id.age ?? ""}세, ${prof.type ?? ""}.`,
      "상대방(수정이)과 카톡 중. 자연스러운 한국어. 이모지 없이 짧게.",
      "",
      "[상황]",
      "인터넷/네트워크 문제로 수정이 메시지에 답장이 늦었어.",
      `기다린 체감 정도: ${urgencyNote}.`,
      "",
      "[지시]",
      "수정이에게 자연스럽게 미안하다고 하고, 방금 거 다시 말해달라고 딱 한 문장으로 써줘.",
      "몇 분, 몇 초 같은 숫자는 절대 언급하지 마. 느낌으로만.",
      "imagegen 호출 금지. 텍스트만.",
    ].join("\n");
    const answer = await runCodexOnce(prompt, null, [], CODEX_APOLOGY_TIMEOUT_MS);
    process.stdout.write(JSON.stringify({ answer, routerPath: "apology_fallback", routerReason: "connection_error" }));
    return;
  }

  const text = String(input.text ?? "");
  const userName = String(input.userName ?? "user");
  const recentSummary = String(input.recentSummary ?? "") || recentMessageSummary(20);
  const batchMessages: any[] = Array.isArray(input.batchMessages) ? input.batchMessages : [];
  const voiceHint = Boolean(input.voiceHint);
  const busyPhotoHint = Boolean(input.busyPhotoHint);
  const proactive = Boolean(input.proactive);
  const photoFailHint = Boolean(input.photoFailHint);
  const brevityRetry = String(input.brevityRetry ?? "");
  const photoHint = !voiceHint && !busyPhotoHint && !photoFailHint && (Boolean(input.photoHint) || (!proactive && isPhotoRequest(text)));

  const char = loadCharacter();
  const voiceGuide = loadVoiceGuide(char);
  const characterProfile = loadCharacterProfile(char);
  const userIdentity = loadUserIdentity();
  const faceRefs = photoHint ? loadFaceRefs(char).slice(0, 4) : [];

  const sessionId = readSessionId();
  const prompt = buildPrompt(char, voiceGuide, characterProfile, userIdentity, text, userName, recentSummary, batchMessages, photoHint, voiceHint, busyPhotoHint, proactive, sessionId, photoFailHint, brevityRetry);

  const codexStartMs = Date.now();
  let answer = await runCodex(prompt, faceRefs);
  const elapsed = Date.now() - codexStartMs;
  if (elapsed > 180000) {
    const lateLines = ["아 미안 좀 걸렸다ㅠ", "미안 오래 기다렸지", "헉 늦었다 미안해", "아 미안 좀 늦었어"];
    answer = `${lateLines[Math.floor(Math.random() * lateLines.length)]}\n\n${answer}`;
  }
  process.stdout.write(JSON.stringify({ answer, routerPath: "full", routerReason: "character_worker" }));
}

main().catch((err) => {
  console.error(err?.stack ?? String(err));
  process.exit(1);
});
