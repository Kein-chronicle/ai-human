const codexBin = process.env.CODEX_BIN ?? "codex";
const model = process.env.CODEX_TELEGRAM_MODEL;
const sessionsRoot = join(homedir(), ".codex", "sessions");
const sessionIdFile = join(stateDir, "codex-session.character.id");
const messagesDir = join(cwd, "messages");
const characterConfigPath = process.env.CHARACTER_CONFIG ?? join(cwd, "character.json");
const userIdentityFile = join(cwd, "state", "user_identity.json");
