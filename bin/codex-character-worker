    if (sticky.length > 0) out.push(`기억해서 꺼낼 것: ${sticky.slice(0, 3).map((s: any) => s.fact ?? s).join(", ")}`);
    out.push(`⚠️ 답변 후 open_loop_digest.json 업데이트.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildMoodResidueSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(moodResidueFile, "utf8"));
    if (!data?.previous_surface_mood || !data?.residue_label) return [];
    return [
      `[감정 잔류]`,
      `직전 무드: ${data.previous_surface_mood} → 현재 잔류: ${data.residue_label} (carry ${Math.round((data.carry_ratio ?? 0.3) * 100)}%)`,
      `↑ 직전 감정이 완전히 사라진 게 아님. 현재 대화에 자연스럽게 녹여낼 것.`,
      "",
    ];
  } catch { return []; }
}

function buildRelationshipDigestSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(relationshipDigestFile, "utf8"));
    const out: string[] = [];
    const pref = data?.preference_bias ?? {};
    const topics: string[] = pref.prefer_topics ?? [];
    const styles: string[] = pref.prefer_styles ?? [];
    const avoid: string[] = pref.avoid_styles ?? [];
    const memKeys: string[] = data?.top_memory_keys ?? [];
    const affection: any[] = data?.affection_patterns ?? [];
    if (topics.length === 0 && styles.length === 0 && memKeys.length === 0 && affection.length === 0) return [];
    out.push(`[관계 컨텍스트 다이제스트]`);
    if (topics.length > 0) out.push(`선호 주제: ${topics.slice(0, 4).join(", ")}`);
    if (styles.length > 0) out.push(`선호 스타일: ${styles.slice(0, 3).join(", ")}`);
    if (avoid.length > 0) out.push(`피할 것: ${avoid.slice(0, 3).join(", ")}`);
    if (memKeys.length > 0) out.push(`핵심 기억 키: ${memKeys.slice(0, 3).join(", ")}`);
    if (affection.length > 0) out.push(`친밀 패턴: ${affection.slice(0, 2).map((a: any) => a.pattern ?? a).join(", ")}`);
    out.push(`⚠️ 새 패턴 발견 시 relationship_context_digest.json 업데이트.`);
    out.push("");
    return out;
  } catch { return []; }
}

function buildSignaturePhrasesSection(): string[] {
  try {
    const data = JSON.parse(readFileSync(join(cwd, "state", "signature_phrases.json"), "utf8"));
    const all: string[] = [];
    for (const pool of Object.values<any>(data?.pools ?? {})) {
      if (Array.isArray(pool)) all.push(...pool.map((p: any) => p.text).filter(Boolean));
    }
    if (all.length === 0) return [];
    const sample = all.sort(() => Math.random() - 0.5).slice(0, 4);
    return [`[은우 말투 어미/표현 샘플]`, `${sample.join(" / ")}`, `↑ 이 중 자연스러운 것 하나 녹이기. 매번 같은 것 쓰지 말 것.`, ""];
  } catch { return []; }
}

