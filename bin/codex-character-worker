const persistentEnvFile = join(cwd, "state", "persistent_environment_state.json");
const openLoopFile = join(cwd, "state", "open_loop_digest.json");
const moodResidueFile = join(cwd, "state", "mood_residue_state.json");
const relationshipDigestFile = join(cwd, "state", "relationship_context_digest.json");
const characterPresenceFile = join(cwd, "state", "character_presence.json");
const conversationPatternFile = join(cwd, "state", "conversation_pattern_state.json");
const replyVarianceFile = join(cwd, "state", "reply_variance_state.json");
const daySatisfactionFile = join(cwd, "state", "day_satisfaction_state.json");
const tasteFrictionFile = join(cwd, "state", "taste_friction_state.json");
const incomingImageContextFile = join(cwd, "state", "incoming_image_context.json");
