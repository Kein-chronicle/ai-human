#!/usr/bin/env bun
// Local HTTP server for chat-viewer. Reads JSONL files fresh on every request.
// Usage: bun run bin/chat-viewer-server
// Access: http://localhost:7890

import { readdirSync, readFileSync, existsSync } from "fs";
import { join } from "path";

const PORT = 7890;
const cwd = process.env.CODEX_TELEGRAM_CWD ?? process.cwd();
const messagesDir = join(cwd, "messages");

function loadData(): Record<string, any[]> {
  const data: Record<string, any[]> = {};
  if (!existsSync(messagesDir)) return data;
  const files = readdirSync(messagesDir)
    .filter((f) => f.endsWith(".jsonl"))
    .sort();
  for (const file of files) {
    const date = file.replace(".jsonl", "");
    const lines = readFileSync(join(messagesDir, file), "utf8")
      .split(/\r?\n/)
      .filter(Boolean);
    const msgs: any[] = [];
    for (const line of lines) {
      try { msgs.push(JSON.parse(line)); } catch {}
    }
    if (msgs.length > 0) data[date] = msgs;
  }
  return data;
}

function buildHtml(data: Record<string, any[]>): string {
  const dataJson = JSON.stringify(data);
  return `<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>응우 대화 기록</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f0f0f5; display: flex; height: 100vh; overflow: hidden; color: #1a1a1a; }
  #sidebar { width: 200px; background: #1c1c2e; color: #eee; display: flex; flex-direction: column; flex-shrink: 0; }
  #sidebar-title { padding: 18px 16px 14px; font-size: 14px; font-weight: 700; color: #a78bfa; border-bottom: 1px solid #2e2e45; letter-spacing: 0.3px; }
  #date-list { overflow-y: auto; flex: 1; }
  .date-item { padding: 10px 16px; cursor: pointer; font-size: 13px; color: #ccc; border-left: 3px solid transparent; transition: all 0.15s; }
  .date-item:hover { background: #2a2a40; color: #fff; }
  .date-item.active { background: #2a2a40; color: #a78bfa; border-left-color: #a78bfa; font-weight: 600; }
  #main { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
  #date-header { padding: 14px 20px; background: #fff; border-bottom: 1px solid #e5e5ea; font-size: 14px; font-weight: 600; color: #555; display: flex; align-items: center; justify-content: space-between; }
  #refresh-btn { font-size: 12px; color: #a78bfa; cursor: pointer; background: none; border: 1px solid #a78bfa; border-radius: 6px; padding: 4px 10px; }
  #refresh-btn:hover { background: #a78bfa22; }
  #messages { flex: 1; overflow-y: auto; padding: 16px 20px; display: flex; flex-direction: column; gap: 8px; }
  .msg-row { display: flex; align-items: flex-end; gap: 8px; max-width: 72%; }
  .msg-row.out { align-self: flex-end; flex-direction: row-reverse; }
  .msg-row.in { align-self: flex-start; }
  .bubble { padding: 9px 13px; border-radius: 18px; font-size: 14px; line-height: 1.5; word-break: break-word; max-width: 100%; }
  .out .bubble { background: #6d5bf0; color: #fff; border-bottom-right-radius: 4px; }
  .in .bubble { background: #fff; color: #1a1a1a; border-bottom-left-radius: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.08); }
  .msg-row.sys { align-self: center; }
  .sys .bubble { background: #e8e8f0; color: #555; font-size: 12px; border-radius: 12px; padding: 5px 12px; }
  .ts { font-size: 10px; color: #aaa; white-space: nowrap; margin-bottom: 2px; flex-shrink: 0; }
  .chat-img { max-width: 220px; max-height: 280px; border-radius: 14px; display: block; cursor: pointer; object-fit: cover; }
  .img-bubble { padding: 4px; }
  .img-caption { font-size: 12px; margin-top: 5px; opacity: 0.85; }
  #lightbox { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.88); z-index: 1000; align-items: center; justify-content: center; cursor: zoom-out; }
  #lightbox.open { display: flex; }
  #lightbox img { max-width: 90vw; max-height: 90vh; border-radius: 8px; object-fit: contain; }
  #stats { padding: 8px 20px; background: #fff; border-top: 1px solid #e5e5ea; font-size: 11px; color: #999; }
  #updated-at { font-size: 10px; color: #bbb; margin-left: 8px; }
</style>
</head>
<body>
<div id="sidebar">
  <div id="sidebar-title">응우 대화</div>
  <div id="date-list"></div>
</div>
<div id="main">
  <div id="date-header">
    <span id="date-label">날짜를 선택하세요</span>
    <button id="refresh-btn" onclick="location.reload()">새로고침</button>
  </div>
  <div id="messages"></div>
  <div id="stats"><span id="stats-text"></span><span id="updated-at">로드: ${new Date().toLocaleTimeString("ko-KR", { timeZone: "Asia/Seoul" })}</span></div>
</div>
<div id="lightbox" onclick="closeLightbox()">
  <img id="lightbox-img" src="" alt="">
</div>
<script>
const DATA = ${dataJson};

function formatTime(ts) {
  try { return new Date(ts).toLocaleTimeString('ko-KR', { hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'Asia/Seoul' }); }
  catch { return ''; }
}
function formatDate(dateStr) {
  try { return new Date(dateStr + 'T00:00:00+09:00').toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'short' }); }
  catch { return dateStr; }
}
function openLightbox(src) {
  document.getElementById('lightbox-img').src = src;
  document.getElementById('lightbox').classList.add('open');
}
function closeLightbox() { document.getElementById('lightbox').classList.remove('open'); }

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/\\n/g,'<br>');
}

function buildMsgHtml(msg) {
  const type = msg.type ?? 'text';
  const dir = msg.direction ?? 'outgoing';
  if (dir === 'system_action') {
    if (type !== 'mode_change') return '';
    return '<div class="msg-row sys"><div class="bubble">⚙️ ' + escHtml(String(msg.mode ?? msg.content ?? type)) + '</div></div>';
  }
  const isOut = dir === 'outgoing';
  const cls = isOut ? 'msg-row out' : 'msg-row in';
  const ts = '<span class="ts">' + formatTime(msg.timestamp) + '</span>';
  let bubbleContent = '';
  if (type === 'image') {
    const src = (msg.path ?? '').startsWith('/') ? 'file://' + msg.path : (msg.path ?? '');
    bubbleContent = '<div class="bubble img-bubble">' +
      (src ? '<img class="chat-img" src="' + src + '" alt="사진" onclick="openLightbox(this.src)" onerror="this.remove()">' : '<span style="opacity:.5">📷 이미지</span>') +
      (msg.caption ? '<div class="img-caption">' + escHtml(msg.caption) + '</div>' : '') + '</div>';
  } else if (type === 'voice_message' || type === 'voice_message_skill_send') {
    bubbleContent = '<div class="bubble">🎤 ' + escHtml(msg.content ?? '[음성 메시지]') + '</div>';
  } else if (type === 'proactive_text') {
    const text = msg.content ?? '';
    if (!text) return '';
    bubbleContent = '<div class="bubble" style="background:#7c6ef0">✦ ' + escHtml(text) + '</div>';
  } else {
    const text = msg.content ?? msg.caption ?? '';
    if (!text) return '';
    bubbleContent = '<div class="bubble">' + escHtml(text) + '</div>';
  }
  return isOut
    ? '<div class="' + cls + '">' + ts + bubbleContent + '</div>'
    : '<div class="' + cls + '">' + bubbleContent + ts + '</div>';
}

const dates = Object.keys(DATA).sort();
const dateList = document.getElementById('date-list');
const messagesEl = document.getElementById('messages');
let currentDate = null;

dates.forEach(date => {
  const item = document.createElement('div');
  item.className = 'date-item';
  item.textContent = date;
  item.dataset.date = date;
  item.onclick = () => showDate(date);
  dateList.appendChild(item);
});

function showDate(date) {
  currentDate = date;
  document.querySelectorAll('.date-item').forEach(el => el.classList.remove('active'));
  const item = document.querySelector('.date-item[data-date="' + date + '"]');
  if (item) item.classList.add('active');
  document.getElementById('date-label').textContent = formatDate(date);
  const msgs = DATA[date] ?? [];
  messagesEl.innerHTML = msgs.map(buildMsgHtml).filter(Boolean).join('');
  const inCount = msgs.filter(m => m.direction === 'incoming').length;
  const outCount = msgs.filter(m => m.direction === 'outgoing').length;
  const imgCount = msgs.filter(m => m.type === 'image').length;
  document.getElementById('stats-text').textContent =
    '받은 ' + inCount + '개  ·  보낸 ' + outCount + '개' + (imgCount > 0 ? '  ·  사진 ' + imgCount + '장' : '') + '  ';
  messagesEl.scrollTop = messagesEl.scrollHeight;
}

if (dates.length > 0) showDate(dates[dates.length - 1]);
</script>
</body>
</html>`;
}

const server = Bun.serve({
  port: PORT,
  fetch(req) {
    const url = new URL(req.url);
    if (url.pathname === "/" || url.pathname === "/index.html") {
      const data = loadData();
      const html = buildHtml(data);
      return new Response(html, { headers: { "content-type": "text/html; charset=utf-8" } });
    }
    return new Response("Not found", { status: 404 });
  },
});

console.log(`[chat-viewer] http://localhost:${PORT}`);
