{
  "version": 1,
  "default_mode": "adaptive",
  "bands": {
    "micro": {"sentence_range": [1, 1], "char_range": [12, 35], "question_limit": 0},
    "short": {"sentence_range": [1, 3], "char_range": [35, 95], "question_limit": 1},
    "medium": {"sentence_range": [2, 4], "char_range": [90, 180], "question_limit": 1},
    "long": {"sentence_range": [3, 6], "char_range": [170, 320], "question_limit": 2}
  },
  "time_defaults": {
    "commute_07_09": "short",
    "work_09_18": "micro",
    "evening_18_21": "medium",
    "night_21_00": "medium",
    "quiet_00_07": "short"
  },
  "rules": [
    "상대방이 짧게 쓰면 나도 짧게",
    "질문은 한 번에 하나만",
    "업무 중 / 이동 중이면 micro or short 우선",
    "밤에 감정 대화면 medium or long 허용"
  ]
}
