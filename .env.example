# ============================================================
# ai-human-maker — Required environment variables
# Copy to .env (or session/.env) and fill in your values
# ============================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenAI API Key (used by Codex for image generation)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs (optional — voice messages)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Azure Speech (optional — alternative TTS)
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# Codex binary path (defaults to 'codex' in PATH)
# CODEX_BIN=/path/to/codex

# Character config path (defaults to character.json in project root)
# CHARACTER_CONFIG=./character.json
