# ============================================================
# ai-human-maker — Required environment variables
# Copy to session/.env and fill in your values
#
# ⚠️ PREREQUISITE: Claude Code (codex) must be installed and
# authenticated on this machine. This system does NOT use the
# OpenAI API — it runs via the local codex CLI.
# Install: https://claude.ai/download (Claude Code)
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── OPTIONAL ─────────────────────────────────────────────────

# ElevenLabs — voice messages
# If not set: voice requests get a hardcoded "no voice available" reply
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here

# Codex binary path (if not in PATH)
# CODEX_BIN=/usr/local/bin/codex

# Azure Speech (alternative TTS if not using ElevenLabs)
# AZURE_SPEECH_KEY=your_azure_speech_key_here
# AZURE_SPEECH_REGION=eastus

# Character config path (defaults to character.json in project root)
# CHARACTER_CONFIG=./character.json
